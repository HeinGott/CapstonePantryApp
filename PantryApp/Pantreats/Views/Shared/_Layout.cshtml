<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChaserPantryApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChaserPantryApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    @{
        var hideNavbar = ViewData["HideNavbar"] as bool? ?? false;
        var fullWidth = ViewData["FullWidth"] as bool? ?? false;
    }

    <div class="pantreats-page-shell">
        @if (!hideNavbar)
        {
            <header>
                <nav class="navbar navbar-expand-sm pantreats-navbar">
                    <div class="container-fluid">
                        <a class="navbar-brand pantreats-brand" asp-area="" asp-controller="Home" asp-action="Index">
                            PanTreats
                        </a>

                        <button class="navbar-toggler pantreats-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Home" asp-action="Index">Home</a>
                                </li>

                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a>
                                    </li>

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Inventory
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Inventory" asp-action="Index">View Inventory</a>
                                            </li>
                                        </ul>
                                    </li>

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Student
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Student" asp-action="Index">View Students</a>
                                            </li>
                                        </ul>
                                    </li>

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Vendor
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Vendor" asp-action="Index">View Vendors</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Vendor" asp-action="Donations">Vendor Donations</a>
                                            </li>
                                        </ul>
                                    </li>

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Reports
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Reports" asp-action="Inventory">Inventory Reports</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Reports" asp-action="Students">Student Reports</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Reports" asp-action="Usage">Pantry Usage</a>
                                            </li>
                                        </ul>
                                    </li>
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Orders
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Order" asp-action="History">Order History</a>
                                            </li>
                                        </ul>
                                    </li>
                                }

                                @if(User.IsInRole("Students"))
                                {       
                                    <li class=" nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Student" asp-action="Apply">Apply</a>
                                    </li>   
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-area="Identity" asp-page="/Account/Shop">Shop</a>
                                    </li>
                                }

                                @if (User.IsInRole("Volunteers"))
                                {
                                    <li class=" nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Volunteer" asp-action="ApplyVolunteer">Apply</a>
                                    </li>
                                }

                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Home" asp-action="About">About</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                </li>
                            </ul>

                            <partial name="_LoginPartial" />
                        </div>
                    </div>
                </nav>
            </header>
        }

        <div class="pantreats-page-content">
            @if (fullWidth)
            {
                <main role="main" class="pantreats-main-full">
                    @RenderBody()
                </main>
            }
            else
            {
                <main role="main" class="pantreats-main-standard">
                    <div class="container pt-4 pb-3">
                        @RenderBody()
                    </div>
                </main>
            }
        </div>

        <footer class="pantreats-footer">
            <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span>&copy; 2026 - PanTreats</span>
                <a asp-controller="Home" asp-action="Privacy" class="pantreats-footer-link">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>