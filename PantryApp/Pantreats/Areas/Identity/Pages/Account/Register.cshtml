@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <div class="student-card p-4 p-md-5">
                <h1 class="text-center mb-3">
                    <img src="/images/SCC-Logo.png" alt="SCC Logo" style="width:380px; height:90px;" />
                </h1>

                @if (Model.ShowRoleChooser)
                {
                    <div class="text-center">
                        <h2 class="mb-2">Register as</h2>
                        <p class="student-page-subtitle mb-4">Choose the kind of account you need before we start the signup flow.</p>

                        <div class="d-grid gap-3">
                            <a asp-page="./Register" asp-route-accountType="student" class="btn btn-primary btn-lg">Student</a>
                            <a asp-page="./Register" asp-route-accountType="donor" class="btn btn-outline-primary btn-lg">Donor</a>
                        </div>

                        <div class="mt-4">
                            <a asp-page="./Login">Already have an account? Sign in</a>
                        </div>
                    </div>
                }
                else
                {
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" asp-route-accountType="@Model.AccountType" method="post">
                        <h2 class="text-center mb-2">
                            @(Model.IsStudentRegistration ? "Create your student account" : "Create your donor account")
                        </h2>
                        <p class="text-center student-page-subtitle mb-4">
                            @(Model.IsStudentRegistration
                                ? "You'll create your login first, then complete the student application."
                                : "We'll set up your donor login and role in one step.")
                        </p>
                        <hr />                        

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>                        

                        @if (Model.IsDonorRegistration)
                        {
                            <div class="mb-3">
                                <label asp-for="Input.FullName" class="form-label">Full Name</label>
                                <input asp-for="Input.FullName" class="form-control" placeholder="Enter your full name" />
                                <span asp-validation-for="Input.FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.PhoneNumber" class="form-label">Phone Number</label>
                                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="(864) 555-1234" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="example@gmail.com" autocomplete="username" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label">Phone Number</label>
                            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="(864) 555-1234" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Password</label>
                            <div class="input-group">
                                <input asp-for="Input.Password" class="form-control" id="registerPasswordInput" placeholder="Enter your password" autocomplete="new-password" />
                                <button class="btn btn-outline-secondary" type="button" id="toggleRegisterPasswordButton">Show</button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                            <div class="input-group">
                                <input asp-for="Input.ConfirmPassword" class="form-control" id="registerConfirmPasswordInput" placeholder="Re-enter your password" autocomplete="new-password" />
                                <button class="btn btn-outline-secondary" type="button" id="toggleRegisterConfirmPasswordButton">Show</button>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-3">
                            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">
                                Register
                            </button>
                            <a asp-page="./Register" class="w-100 btn btn-lg btn-outline-secondary">
                                Back
                            </a>
                        </div>
                    </form>

                    @if (Model.IsStudentRegistration && Model.ExternalLogins.Any())
                    {
                        <div class="text-center mt-4">
                            <p class="mb-3 fs-5">Or continue with Microsoft</p>
                            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" asp-route-accountType="student" method="post">
                                <button type="submit" class="btn p-0 border-0 bg-transparent" name="provider" value="Microsoft" title="Register with Microsoft">
                                    <img src="~/images/microsoftLoginIcon.svg" asp-append-version="true" alt="Continue with Microsoft" style="height:44px; width:auto;" />
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function wirePasswordToggle(inputId, buttonId) {
            const input = document.getElementById(inputId);
            const button = document.getElementById(buttonId);

            if (!input || !button) {
                return;
            }

            button.addEventListener("click", function () {
                if (input.type === "password") {
                    input.type = "text";
                    button.textContent = "Hide";
                }
                else {
                    input.type = "password";
                    button.textContent = "Show";
                }
            });
        }

        wirePasswordToggle("registerPasswordInput", "toggleRegisterPasswordButton");
        wirePasswordToggle("registerConfirmPasswordInput", "toggleRegisterConfirmPasswordButton");
    </script>
}
