@{
    ViewData["Title"] = "Create Donation";
    Layout = "_Layout";
}

<div class="donor-page">
    <div class="donor-page-header">
        <div>
            <h1 class="donor-page-title">Make a Donation</h1>
            <p class="donor-page-subtitle">Select the items and quantities you would like to donate.</p>
        </div>
        <a asp-controller="Donor" asp-action="Dashboard" class="btn donor-secondary-btn">Back to Dashboard</a>
    </div>

    <div class="donor-card">
        <form asp-controller="Donor" asp-action="CreateDonation" method="post">
            @Html.AntiForgeryToken()

            <div class="table-responsive">
                <table class="table donor-table">
                    <thead>
                        <tr>
                            <th>Donate</th>
                            <th>Category</th>
                            <th>Quantity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var items = new[] { "Canned Goods", "Produce", "Meat", "Bread & Bakery",
                                                "Rice & Pasta", "Dairy Products", "Frozen Foods",
                                                "Snacks", "Beverages", "Hygiene Products",
                                                "Baby Supplies", "Pet Food" };
                        }
                        @for (int i = 0; i < items.Length; i++)
                        {
                            <input type="hidden" name="items[@i].Name" value="@items[i]" />
                            <tr class="donor-row">
                                <td><input type="checkbox" name="items[@i].Selected" value="true" /></td>
                                <td>@items[i]</td>
                                <td><input type="number" name="items[@i].Quantity" min="1" value="1" class="form-control" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-4 text-end">
                <button type="submit" class="btn donor-primary-btn">Submit Donation</button>
            </div>
        </form>
    </div>
</div>