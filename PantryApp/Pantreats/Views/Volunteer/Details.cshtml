@model Pantreats.Models.VolunteerDetailsViewModel

@{
    ViewData["Title"] = "Volunteer Details";

    string FormatDateTime(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("MM/dd/yyyy h:mm tt") : "Not reviewed yet";
    string FormatBool(bool value) => value ? "Yes" : "No";

    var availability = new List<string>();
    if (Model.MonMorning) availability.Add("Mon AM");
    if (Model.MonAfternoon) availability.Add("Mon PM");
    if (Model.TueMorning) availability.Add("Tue AM");
    if (Model.TueAfternoon) availability.Add("Tue PM");
    if (Model.WedMorning) availability.Add("Wed AM");
    if (Model.WedAfternoon) availability.Add("Wed PM");
    if (Model.ThuMorning) availability.Add("Thu AM");
    if (Model.ThuAfternoon) availability.Add("Thu PM");
    if (Model.FriMorning) availability.Add("Fri AM");
    if (Model.FriAfternoon) availability.Add("Fri PM");
    if (Model.SatMorning) availability.Add("Sat AM");
    if (Model.SatAfternoon) availability.Add("Sat PM");
    if (Model.SunMorning) availability.Add("Sun AM");
    if (Model.SunAfternoon) availability.Add("Sun PM");
}

<div class="student-details-page py-4">
    <div class="mb-3 d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <a asp-action="Index" class="btn student-back-btn">&larr; Back to Volunteers</a>

        <form asp-action="DeleteApplication"
              asp-route-id="@Model.VolunteerApplicationId"
              method="post"
              onsubmit="return confirm('Are you sure you want to delete this volunteer application? This cannot be undone.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                Delete Application
            </button>
        </form>
    </div>

    <section class="student-review-shell mb-4">
        <div class="student-review-hero">
            <div>
                <p class="student-review-eyebrow mb-2">Application Review</p>
                <h1 class="student-details-title mb-1">@Model.FullName</h1>
                <p class="student-details-subtitle mb-1">Year: @Model.Year</p>
            </div>

            <div class="student-review-status-wrap">
                <span class="student-review-badge student-review-badge-@Model.ApplicationStatus.ToLowerInvariant()">
                    @Model.ApplicationStatus
                </span>
            </div>
        </div>

        <div class="student-review-summary">
            <div class="student-review-summary-item">
                <span>Year</span>
                <strong>@Model.Year</strong>
            </div>
            <div class="student-review-summary-item">
                <span>Frequency</span>
                <strong>@Model.VolunteerFrequency</strong>
            </div>
            <div class="student-review-summary-item">
                <span>Submitted</span>
                <strong>@FormatDateTime(Model.SubmittedAt)</strong>
            </div>
            <div class="student-review-summary-item">
                <span>Reviewed</span>
                <strong>@FormatDateTime(Model.ReviewedAt)</strong>
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Contact</h2>
                <p class="student-page-subtitle mb-0">Core volunteer information.</p>
            </div>
        </div>

        <div class="student-fact-list">
            <div class="student-fact-row">
                <span>Full name</span>
                <strong>@Model.FullName</strong>
            </div>
            <div class="student-fact-row">
                <span>Email</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Email) ? "Not available" : Model.Email)</strong>
            </div>
            <div class="student-fact-row">
                <span>Phone number</span>
                <strong>@Model.DisplayPhoneNumber</strong>
            </div>
            <div class="student-fact-row">
                <span>Year</span>
                <strong>@Model.Year</strong>
            </div>
            <div class="student-fact-row">
                <span>Application record</span>
                <strong>#@Model.VolunteerApplicationId</strong>
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Availability</h2>
                <p class="student-page-subtitle mb-0">Days and times the volunteer can help.</p>
            </div>
        </div>

        <div class="student-fact-list student-fact-list-compact">
            <div class="student-fact-row">
                <span>How often</span>
                <strong>@Model.VolunteerFrequency</strong>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.OtherFrequency))
            {
                <div class="student-fact-row student-fact-subrow">
                    <span>Other frequency</span>
                    <strong>@Model.OtherFrequency</strong>
                </div>
            }
            <div class="student-fact-stack">
                <span>Weekly slots</span>
                @if (availability.Any())
                {
                    <div class="student-support-pills student-support-pills-tight">
                        @foreach (var slot in availability)
                        {
                            <span class="student-support-pill active">@slot</span>
                        }
                    </div>
                }
                else
                {
                    <strong>No availability selected</strong>
                }
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Experience</h2>
                <p class="student-page-subtitle mb-0">Background and motivation.</p>
            </div>
        </div>

        <div class="student-fact-list">
            <div class="student-fact-row">
                <span>Volunteered before</span>
                <strong>@FormatBool(Model.HasVolunteeredBefore)</strong>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.PreviousCapacity))
            {
                <div class="student-fact-row student-fact-subrow">
                    <span>Previous capacity</span>
                    <strong>@Model.PreviousCapacity</strong>
                </div>
            }
        </div>

        <div class="student-review-note mt-4">
            <span>Why they want to volunteer</span>
            <p class="mb-0">@Model.ReasonForVolunteering</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ReviewNotes))
        {
            <div class="student-review-note mt-4">
                <span>Latest Review Notes</span>
                <p class="mb-0">@Model.ReviewNotes</p>
            </div>
        }
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Decision</h2>
                <p class="student-page-subtitle mb-0">Approve or reject after reviewing the application details.</p>
            </div>
        </div>

        @if (Model.ApplicationStatus == Pantreats.Models.ApplicationStatuses.Pending)
        {
            <div class="student-decision-grid">
                <form asp-action="Approve" asp-route-id="@Model.VolunteerApplicationId" method="post" class="student-decision-form student-decision-form-approve">
                    @Html.AntiForgeryToken()
                    <label class="form-label">Approval notes</label>
                    <textarea name="reviewNotes" class="form-control" rows="4" placeholder="Optional note for the application record"></textarea>
                    <button type="submit" class="btn btn-success mt-3">Approve Volunteer</button>
                </form>

                <form asp-action="Reject" asp-route-id="@Model.VolunteerApplicationId" method="post" class="student-decision-form student-decision-form-reject">
                    @Html.AntiForgeryToken()
                    <label class="form-label">Rejection notes</label>
                    <textarea name="reviewNotes" class="form-control" rows="4" placeholder="Tell the applicant what needs to be fixed"></textarea>
                    <button type="submit" class="btn btn-outline-danger mt-3">Reject Application</button>
                </form>
            </div>
        }
        else
        {
            <div class="student-fact-list">
                <div class="student-fact-row">
                    <span>Current status</span>
                    <strong>@Model.ApplicationStatus</strong>
                </div>
                <div class="student-fact-row">
                    <span>Reviewed on</span>
                    <strong>@FormatDateTime(Model.ReviewedAt)</strong>
                </div>
            </div>
        }
    </section>
</div>
