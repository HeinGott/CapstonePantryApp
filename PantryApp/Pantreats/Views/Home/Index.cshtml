@{
    ViewData["Title"] = "Home";
    ViewData["FullWidth"] = true;
}

<section class="pantreats-hero-section">
    <div class="container">
        <div class="row align-items-center g-4">

            <div class="col-lg-6 text-center">
                <div class="hero-logo-panel">
                    <img src="~/images/pantreatsLogo.png" alt="PanTreats logo" class="img-fluid pantreats-hero-logo" />
                </div>
            </div>

            <div class="col-lg-6 text-center text-lg-start">
                <h1 class="hero-title mb-3">
                    Campus pantry support, made simple.
                </h1>

                <p class="hero-text mb-4">
                    PanTreats helps students and households apply for support, shop pantry items,
                    and schedule visits in a private, easy to use online space.
                </p>
            </div>

        </div>
    </div>
</section>

<section class="pantreats-white-section" id="services">
    <div class="container">
        <div class="section-heading text-center mb-4">
            <h2 class="section-title">What You Can Do With PanTreats?</h2>
            <p class="section-text">
                Built for pantry users, staff, and campus teams working together to reduce food insecurity.
            </p>
        </div>

        <!--Pulls up Pantry-->
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Shop" asp-action="Index" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Shop the Pantry</h5>
                            <p class="text-muted mb-0">
                                Use a virtual pantry experience to request food and select items that fit your household’s needs.
                            </p>
                        </div>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Shop the Pantry</h5>
                            <p class="text-muted mb-0">
                                Use a virtual pantry experience to request food and select items that fit your household’s needs.
                            </p>
                        </div>
                    </a>
                }
            </div>

            <!--Pulls up Student Application-->
            <div class="col-md-6 col-xl-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Student" asp-action="Apply" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Apply Online</h5>
                            <p class="text-muted mb-0">
                                Register online, share household information, and complete intake without unnecessary barriers.
                            </p>
                        </div>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Apply Online</h5>
                            <p class="text-muted mb-0">
                                Register online, share household information, and complete intake without unnecessary barriers.
                            </p>
                        </div>
                    </a>
                }
            </div>


            <!--Pulls up Recipes-->
            <div class="col-md-6 col-xl-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Recipe" asp-action="Index" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Browse Recipes</h5>
                            <p class="text-muted mb-0">
                                Browse the pantrys recipes for a nice meal, or just to try something new!
                            </p>
                        </div>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Browse Recipes</h5>
                            <p class="text-muted mb-0">
                                Browse the pantrys recipes for a nice meal, or just to try something new!
                            </p>
                        </div>
                    </a>
                }
            </div>

            <!--Pulls up Order History-->
            <div class="col-md-6 col-xl-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Order" asp-action="History" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Track Services</h5>
                            <p class="text-muted mb-0">
                                Record pantry visits, food distributions, referrals, and services provided across one or more locations.
                            </p>
                        </div>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none">
                        <div class="info-card h-100 text-center p-4">
                            <h5 class="fw-bold">Track Services</h5>
                            <p class="text-muted mb-0">
                                Record pantry visits, food distributions, referrals, and services provided across one or more locations.
                            </p>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<section class="pantreats-blue-section" id="how-it-works">
    <div class="container">

        <div class="section-heading text-center mb-4">
            <h2 class="section-title section-title-light">How It Works</h2>
            <p class="section-text section-text-light">
                Designed to support both pantry access and pantry operations.
            </p>
        </div>

        <div class="row g-4">
                <div class="col-md-4">
                <!--Brings to register/Login page-->
                <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none">
                
                        <div class="step-card h-100 p-4 text-center">
                            <h5 class="fw-bold">Create an Account</h5>
                            <p class="text-muted mb-0">
                                Students and pantry users can register online and securely enter household and contact information.
                            </p>
                        </div>
            
                </a>
            </div>

        
            <!--Brings to shop-->
            <div class="col-md-4">
                <a asp-controller="Shop" asp-action="Index" class="text-decoration-none">
                
                        <div class="step-card h-100 p-4 text-center">
                            <h5 class="fw-bold">Request Support</h5>
                            <p class="text-muted mb-0">
                                Apply for pantry services, shop available items, and choose pickup or service options that work best.
                            </p>
                        </div>
                
                </a>
            </div>

            <!--Brings to Volunteer Application-->
            <div class="col-md-4">
                <a asp-controller="Volunteer" asp-action="ApplyVolunteer" class="text-decoration-none">

                    <div class="step-card h-100 p-4 text-center">
                        <h5 class="fw-bold">Serve and Track</h5>
                        <p class="text-muted mb-0">
                            Pantry staff and volunteers can manage inventory, appointments, visits, and reporting all in one platform.
                        </p>
                    </div>

                </a>
                
            </div>
        </div>
    </div>
</section>

<section class="pantreats-white-section" id="help">
    <div class="container">
        <div class="row justify-content-center text-center g-4">
            <div class="col-lg-8">

                <h2 class="section-title mb-3">
                    Built for Real Pantry Work
                </h2>

                <p class="section-text mb-3">
                    PanTreats supports the work behind the scenes too. From client records and pantry inventory
                    to volunteer coordination, service tracking, and reporting.
                </p>

                <p class="section-text mb-0">
                    Whether one campus pantry is getting started or multiple locations are working together,
                    PanTreats helps teams stay organized and serve people with dignity.
                </p>

            </div>
        </div>
    </div>
</section>
