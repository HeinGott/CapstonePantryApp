@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="admin-dashboard py-4">

    <section class="admin-hero mb-4">
        <div class="row align-items-center g-4">

            <div class="col-lg-9">
                <h1 class="admin-page-title mb-2">Admin Dashboard</h1>

                <p class="admin-page-subtitle mb-0">
                    Use the sections below to manage students, inventory, vendors, and reporting tools as your system grows.
                </p>
            </div>

            <div class="col-lg-3">
                <div class="admin-hero-side-card">
                    <div class="admin-hero-side-label">Welcome</div>

                    <div class="admin-hero-side-value">
                        Lerkeshia Littlejohn
                    </div>
                </div>
            </div>

        </div>
    </section>

    <section class="admin-stats mb-4">
        <div class="row g-4">

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card">
                    <div>
                        <div class="admin-stat-label">Student Visits</div>
                        <div class="admin-stat-value">0</div>
                        <div class="admin-stat-note">This month</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card">
                    <div>
                        <div class="admin-stat-label">Points Used</div>
                        <div class="admin-stat-value">0</div>
                        <div class="admin-stat-note">Tracked monthly activity</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card">
                    <div>
                        <div class="admin-stat-label">Low Stock Items</div>
                        <div class="admin-stat-value">0</div>
                        <div class="admin-stat-note">Needs restocking</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card">
                    <div>
                        <div class="admin-stat-label">Monthly Limit Claims</div>
                        <div class="admin-stat-value">0</div>
                        <div class="admin-stat-note">Current cycle</div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <section class="admin-reporting mb-4">
        <div class="row g-4">

            <div class="col-lg-6">
                <div class="admin-panel h-100">
                    <div class="admin-panel-header">
                        <div>
                            <span class="admin-panel-kicker">Inventory Patterns</span>
                            <h2 class="admin-panel-title mb-1">Top Item Categories</h2>
                        </div>
                    </div>

                    <div class="category-list mt-4">

                        <div class="category-row">
                            <span>Snacks</span>
                            <strong>40%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 40%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Beverages</span>
                            <strong>40%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 40%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Meals</span>
                            <strong>16%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 16%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Hygiene</span>
                            <strong>4%</strong>
                        </div>
                        <div class="progress admin-progress">
                            <div class="progress-bar" style="width: 4%;"></div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="admin-panel h-100">
                    <div class="admin-panel-header">
                        <div>
                            <span class="admin-panel-kicker">Visit Patterns</span>
                            <h2 class="admin-panel-title mb-1">Busiest Days</h2>
                        </div>
                    </div>

                    <div class="category-list mt-4">

                        <div class="category-row">
                            <span>Monday</span>
                            <strong>22%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 22%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Tuesday</span>
                            <strong>26%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 26%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Wednesday</span>
                            <strong>24%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 24%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Thursday</span>
                            <strong>21%</strong>
                        </div>
                        <div class="progress admin-progress mb-3">
                            <div class="progress-bar" style="width: 21%;"></div>
                        </div>

                        <div class="category-row">
                            <span>Friday</span>
                            <strong>7%</strong>
                        </div>
                        <div class="progress admin-progress">
                            <div class="progress-bar" style="width: 7%;"></div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </section>

    <section class="admin-management">
        <div class="mb-3">
            <h2 class="admin-section-title mb-1">Management Areas</h2>

            <p class="admin-section-text mb-0">
                Access the major areas used to manage pantry operations.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-xl-4">
                <div class="admin-tile">
                    <div class="admin-tile-content">
                        <h3 class="admin-tile-title">Item Requests</h3>

                        <p class="admin-tile-text">
                            Review pantry requests submitted by users.
                        </p>
                    </div>

                    <a asp-area="Identity"
                           asp-page="/Account/ItemRequests"
                           class="btn admin-tile-btn">
                        View Requests
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="admin-tile">
                    <div class="admin-tile-content">
                        <h3 class="admin-tile-title">Students</h3>

                        <p class="admin-tile-text">
                            Manage student records, badge lookup details, and pantry access history.
                        </p>
                    </div>

                    <a asp-controller="Student" asp-action="Index" class="btn admin-tile-btn">
                        View Students
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="admin-tile">
                    <div class="admin-tile-content">
                        <h3 class="admin-tile-title">Inventory</h3>

                        <p class="admin-tile-text">
                            Track item quantities, restocking needs, and pantry item rules.
                        </p>
                    </div>

                    <a asp-controller="Inventory" asp-action="Index" class="btn admin-tile-btn">
                        View Inventory
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="admin-tile">
                    <div class="admin-tile-content">
                        <h3 class="admin-tile-title">Order Fulfilemnt</h3>

                        <p class="admin-tile-text">
                            Manage order statuses, fulfilment dates, orders received, and complected pantry orders.
                        </p>
                    </div>

                    <a asp-controller="OrderFulfilments" asp-action="Index" class="btn admin-tile-btn">
                        View Order Fulfilemnt
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="admin-tile">
                    <div class="admin-tile-content">
                        <h3 class="admin-tile-title">Vendors</h3>

                        <p class="admin-tile-text">
                            Record vendor details, order history, and contact information.
                        </p>
                    </div>

                    <a asp-controller="Vendor" asp-action="Index" class="btn admin-tile-btn">
                        View Vendors
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="admin-tile">
                    <div class="admin-tile-content">
                        <h3 class="admin-tile-title">Order History</h3>

                        <p class="admin-tile-text">
                            History of all past orders, including order details, dates, and totals.
                        </p>
                    </div>

                    <a asp-controller="Order" asp-action="History" class="btn admin-tile-btn">
                        View Orders
                    </a>
                </div>
            </div>

        </div>
    </section>

</div>