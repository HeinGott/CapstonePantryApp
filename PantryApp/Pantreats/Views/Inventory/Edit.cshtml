@model Pantreats.Models.Inventory

<h2>Edit Inventory Item</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="UPC" />

    <div class="mb-2">
        <label>Item Name</label>
        <input asp-for="ItemName" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Brand</label>
        <input asp-for="BrandName" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Category</label>
        <input asp-for="Category" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Subcategory</label>
        <input asp-for="Subcategory" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Use</label>
        <input asp-for="GenderUse" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Unit Size</label>
        <input asp-for="UnitSize" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Quantity</label>
        <input asp-for="Quantity" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">
        Save Changes
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>