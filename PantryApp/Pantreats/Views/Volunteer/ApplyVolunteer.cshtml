@model VolunteerApplicationViewModel
@{
    ViewData["Title"] = "Volunteer Application";
    ViewData["FullWidth"] = true;
}

<div class="pantreats-white-section">
    <div class="container">

        <div class="student-card mx-auto" style="max-width: 1100px;">

            <!-- Header -->
            <div class="mb-4 text-center">
                <img src="/Images/pantreatsLogo.png" class="mb-3" style="max-width: 220px;">
                <h1 class="section-title">Volunteer Application</h1>
                <p class="section-text">Thank you for your interest in volunteering with PanTreats!</p>
            </div>            

            <form asp-controller="Volunteer" asp-action="VolunteerApplicationForm" method="post">
                @Html.AntiForgeryToken()

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Basic Info -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Basic Information</h5>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <input asp-for="PhoneNum" class="form-control" />
                        <span asp-validation-for="PhoneNum" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    
                </div>

                <!-- Volunteer Experience -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Volunteer Experience</h5>
                             
                <div class="mb-4">
                    <label class="form-label">Why do you want to volunteer?</label>
                    <textarea asp-for="ReasonForVolunteering" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="ReasonForVolunteering" class="text-danger"></span>
                </div>

                <!-- Volunteer Frequency -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Volunteer Frequency</h5>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">How often are you interested in volunteering?</label>
                        <select asp-for="VolunteerFrequency" class="form-select">
                            <option value="">-- Select Frequency --</option>
                            <option value="As Needed">As often as needed</option>
                            <option value="Weekly">Once a week</option>
                            <option value="Monthly">Once a month</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="VolunteerFrequency" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">If "Other," please specify</label>
                        <input asp-for="OtherFrequency" class="form-control" />
                    </div>
                </div>

                <!-- Weekly Availability -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Weekly Availability</h5>
                <p class="text-muted small">Check the days and times you are available:</p>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered text-center align-middle">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th>
                                <th>Fri</th><th>Sat</th><th>Sun</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <th>9 – 1 p.m.</th>
                                <td><input asp-for="MonMorning" class="form-check-input" /></td>
                                <td><input asp-for="TueMorning" class="form-check-input" /></td>
                                <td><input asp-for="WedMorning" class="form-check-input" /></td>
                                <td><input asp-for="ThuMorning" class="form-check-input" /></td>
                                <td><input asp-for="FriMorning" class="form-check-input" /></td>
                                <td><input asp-for="SatMorning" class="form-check-input" /></td>
                                <td><input asp-for="SunMorning" class="form-check-input" /></td>
                            </tr>
                            <tr>
                                <th>1 – 5 p.m.</th>
                                <td><input asp-for="MonAfternoon" class="form-check-input" /></td>
                                <td><input asp-for="TueAfternoon" class="form-check-input" /></td>
                                <td><input asp-for="WedAfternoon" class="form-check-input" /></td>
                                <td><input asp-for="ThuAfternoon" class="form-check-input" /></td>
                                <td><input asp-for="FriAfternoon" class="form-check-input" /></td>
                                <td><input asp-for="SatAfternoon" class="form-check-input" /></td>
                                <td><input asp-for="SunAfternoon" class="form-check-input" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Submit -->
                <div class="text-center mt-4">
                    <button type="submit" class="btn admin-tile-btn-featured px-5 py-2">
                        Submit Application
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
