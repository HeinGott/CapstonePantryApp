@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    var isStudentRegistration = Model.RegistrationType == "student";
    var isDonorRegistration = Model.RegistrationType == "donor";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <h1 class="text-center mb-3">
                <img src="/images/SCC-Logo.png" alt="SCC Logo"
                     style="width:380px; height:90px;" />
            </h1>

            @if (!isStudentRegistration && !isDonorRegistration)
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5 text-center">
                        <h2 class="mb-2">Register as</h2>
                        <p class="text-muted mb-4">Choose the account type you want to create.</p>

                        <div class="d-grid gap-3">
                            <a asp-page="./Register"
                               asp-route-role="student"
                               asp-route-returnUrl="@Model.ReturnUrl"
                               class="btn btn-primary btn-lg">
                                Student
                            </a>
                            <a asp-page="./Register"
                               asp-route-role="donor"
                               asp-route-returnUrl="@Model.ReturnUrl"
                               class="btn btn-outline-primary btn-lg">
                                Donor
                            </a>
                        </div>

                        <div class="mt-4">
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                                Already have an account? Log in
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <input type="hidden" asp-for="RegistrationType" />

                    <h2 class="text-center">
                        @(isDonorRegistration ? "Create your donor account" : "Create your student account")
                    </h2>
                    <p class="text-center text-muted mb-3">
                        @(isDonorRegistration
                            ? "Your donor role will be assigned automatically when this account is created."
                            : "You'll create your login first, then complete the student application.")
                    </p>
                    <hr />

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    @if (isDonorRegistration)
                    {
                        <div class="mb-3">
                            <label asp-for="Input.FullName" class="form-label">Full Name</label>
                            <input asp-for="Input.FullName" class="form-control"
                                   placeholder="Enter your full name" />
                            <span asp-validation-for="Input.FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label">Phone Number</label>
                            <input asp-for="Input.PhoneNumber" class="form-control"
                                   placeholder="(864) 555-1234" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control"
                               placeholder="example@gmail.com"
                               autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <div class="input-group">
                            <input asp-for="Input.Password" class="form-control"
                                   id="registerPasswordInput"
                                   placeholder="Enter your password"
                                   autocomplete="new-password" />
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    id="toggleRegisterPasswordButton">
                                Show
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <input asp-for="Input.ConfirmPassword" class="form-control"
                                   id="registerConfirmPasswordInput"
                                   placeholder="Re-enter your password"
                                   autocomplete="new-password" />
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    id="toggleRegisterConfirmPasswordButton">
                                Show
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-3">
                        <button id="registerSubmit" type="submit"
                                class="btn btn-lg btn-primary">
                            Register
                        </button>

                        <a asp-page="./Register"
                           asp-route-returnUrl="@Model.ReturnUrl"
                           class="btn btn-outline-secondary">
                            Back
                        </a>
                    </div>

                </form>

                @if (isStudentRegistration && Model.ExternalLogins != null && Model.ExternalLogins.Count > 0)
                {
                    <div class="mt-4 text-center">
                        <p class="text-muted mb-2">
                            Or continue with Microsoft
                        </p>

                        <form asp-page="./ExternalLogin"
                              asp-route-returnUrl="@Model.ReturnUrl"
                              method="post"
                              class="d-flex justify-content-center">
                            @foreach (var provider in Model.ExternalLogins)
                            {
                                if (provider.Name == "Microsoft")
                                {
                                    <button type="submit"
                                            name="provider"
                                            value="@provider.Name"
                                            class="microsoft-login-icon-button"
                                            title="Register with Microsoft"
                                            aria-label="Register with Microsoft">
                                        <img src="~/images/microsoftLoginIcon.svg"
                                             alt="Microsoft login"
                                             class="microsoft-login-icon" />
                                    </button>
                                }
                            }
                        </form>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function wirePasswordToggle(inputId, buttonId) {
            const input = document.getElementById(inputId);
            const button = document.getElementById(buttonId);

            if (!input || !button) {
                return;
            }

            button.addEventListener("click", function () {
                if (input.type === "password") {
                    input.type = "text";
                    button.textContent = "Hide";
                }
                else {
                    input.type = "password";
                    button.textContent = "Show";
                }
            });
        }

        wirePasswordToggle("registerPasswordInput", "toggleRegisterPasswordButton");
        wirePasswordToggle("registerConfirmPasswordInput", "toggleRegisterConfirmPasswordButton");
    </script>
}
