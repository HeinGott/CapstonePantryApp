@*
   this the register page for vendors, it will be used to create a new vendor account in the system.
   made by eric and jorge
*@
@{
    ViewData["Title"] = "Donor Registration";
}
@model Donor
<form asp-controller="Donor" asp-action="Register" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="d-flex justify-content-center mt-4">
        <div style="width: 420px;">

            <h2 class="text-center mb-3">Donor Registration</h2>
            <hr />

            

                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text"
                           name="Name"
                           class="form-control"
                           placeholder="Enter your full name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email"
                           name="Email"
                           class="form-control"
                           placeholder="example@gmail.com" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Phone Number</label>
                    <input type="text"
                           name="PhoneNumber"
                           class="form-control"
                           placeholder="(864) 555-1234" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input type="password"
                               name="Password"
                               id="donorRegisterPasswordInput"
                               class="form-control"
                               placeholder="Enter your password" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="toggleDonorRegisterPasswordButton">
                            Show
                        </button>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <div class="input-group">
                        <input type="password"
                               name="ConfirmPassword"
                               id="donorRegisterConfirmPasswordInput"
                               class="form-control"
                               placeholder="Confirm your password" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="toggleDonorRegisterConfirmPasswordButton">
                            Show
                        </button>
                    </div>
                </div>

                <button type="submit"
                        class="btn btn-primary w-100">
                    Register
                </button>

                <div class="text-center mt-4">
                    <a asp-controller="Donor"
                       asp-action="Login">
                        Already have an account? Login
                    </a>
                </div>

           

        </div>
    </div>
</form>

@section Scripts {
    <script>
        function wirePasswordToggle(inputId, buttonId) {
            const input = document.getElementById(inputId);
            const button = document.getElementById(buttonId);

            button.addEventListener("click", function () {
                if (input.type === "password") {
                    input.type = "text";
                    button.textContent = "Hide";
                }
                else {
                    input.type = "password";
                    button.textContent = "Show";
                }
            });
        }

        wirePasswordToggle("donorRegisterPasswordInput", "toggleDonorRegisterPasswordButton");
        wirePasswordToggle("donorRegisterConfirmPasswordInput", "toggleDonorRegisterConfirmPasswordButton");
    </script>
}
