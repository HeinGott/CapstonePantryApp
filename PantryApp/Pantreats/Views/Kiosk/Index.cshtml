<div class="kiosk-shell">
    <div class="kiosk-stage">
        <div class="kiosk-panel kiosk-panel-primary" id="kioskLookupPanel">
            <div class="kiosk-panel-copy">
                <img src="~/images/SCC-Logo.png" alt="Spartanburg Community College logo" class="kiosk-school-logo" />
                <span class="kiosk-eyebrow">PanTreats Self Checkout</span>
                <h1 class="kiosk-title">Scan student ID to begin</h1>
                <p class="kiosk-subtitle">
                    Students can scan their badge or type their student ID number to start checkout.
                </p>
            </div>

            <div class="kiosk-field-stack">
                @Html.AntiForgeryToken()
                <label class="form-label kiosk-label" for="studentIdInput">Student ID number</label>
                <div class="kiosk-input-row">
                    <input id="studentIdInput"
                           class="form-control form-control-lg kiosk-input"
                           inputmode="numeric"
                           autocomplete="off"
                           placeholder="Scan or enter student ID" />
                    <button type="button" class="btn btn-primary kiosk-action-button" id="studentLookupButton">
                        Continue
                    </button>
                </div>
                <div class="kiosk-status" id="lookupStatus" aria-live="polite"></div>
            </div>
        </div>

        <div class="kiosk-panel d-none" id="kioskCheckoutPanel">
            <div class="kiosk-student-bar">
                <div>
                    <span class="kiosk-eyebrow">Checked In Student</span>
                    <h2 class="kiosk-student-name" id="studentNameDisplay"></h2>
                    <p class="kiosk-student-id" id="studentIdDisplay"></p>
                </div>

                <button type="button" class="btn btn-outline-secondary" id="startOverButton">
                    Start Over
                </button>
            </div>

            <div class="kiosk-work-grid">
                <section class="kiosk-section">
                    <h3 class="kiosk-section-title">Scan items</h3>
                    <p class="kiosk-section-text">Scan each item barcode to add it to this checkout.</p>

                    <div class="kiosk-input-row">
                        <input id="itemUpcInput"
                               class="form-control form-control-lg kiosk-input"
                               autocomplete="off"
                               placeholder="Scan item barcode" />
                        <button type="button" class="btn btn-primary kiosk-action-button" id="itemLookupButton">
                            Add Item
                        </button>
                    </div>

                    <div class="kiosk-status" id="itemStatus" aria-live="polite"></div>
                </section>

                <section class="kiosk-section kiosk-cart-section">
                    <div class="kiosk-cart-header">
                        <h3 class="kiosk-section-title">Checkout list</h3>
                        <span class="kiosk-cart-count" id="cartCountDisplay">0 items</span>
                    </div>

                    <div class="kiosk-empty-state" id="emptyCartState">
                        No items scanned yet.
                    </div>

                    <div class="table-responsive d-none" id="cartTableWrap">
                        <table class="table kiosk-table mb-0">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>UPC</th>
                                    <th>Qty</th>
                                    <th>Points</th>
                                    <th class="text-end">Subtotal</th>
                                    <th class="text-end">Adjust</th>
                                </tr>
                            </thead>
                            <tbody id="cartTableBody"></tbody>
                        </table>
                    </div>

                    <div class="kiosk-total-row">
                        <div>
                            <span class="kiosk-total-label">Total points</span>
                            <strong class="kiosk-total-value" id="totalPointsDisplay">0</strong>
                        </div>

                        <button type="button" class="btn btn-success kiosk-checkout-button" id="checkoutButton" disabled>
                            Complete Checkout
                        </button>
                    </div>

                    <div class="kiosk-status" id="checkoutStatus" aria-live="polite"></div>
                </section>
            </div>
        </div>

        <div class="kiosk-panel kiosk-panel-primary d-none" id="kioskCompletePanel">
            <div class="kiosk-panel-copy kiosk-complete-copy">
                <img src="~/images/SCC-Logo.png" alt="Spartanburg Community College logo" class="kiosk-school-logo" />
                <span class="kiosk-eyebrow">Order Complete</span>
                <h1 class="kiosk-title kiosk-complete-title">Thanks for visiting the pantry</h1>
                <div class="kiosk-complete-details">
                    <p><span>Order #</span><strong id="completeOrderNumber"></strong></p>
                    <p><span>Date</span><strong id="completeOrderDate"></strong></p>
                </div>
                <p class="kiosk-subtitle kiosk-complete-subtitle">We hope to see you again soon.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="checkoutConfirmModal" tabindex="-1" aria-labelledby="checkoutConfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered kiosk-confirm-dialog">
        <div class="modal-content kiosk-confirm-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="checkoutConfirmTitle">Confirm checkout</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body kiosk-confirm-body">
                <div class="kiosk-receipt">
                    <div class="kiosk-receipt-student">
                        <div>
                            <span>Student</span>
                            <strong id="confirmStudentDisplay"></strong>
                        </div>
                        <div>
                            <span>Items</span>
                            <strong id="confirmItemCountDisplay"></strong>
                        </div>
                        <div>
                            <span>Total points</span>
                            <strong id="confirmTotalPointsDisplay"></strong>
                        </div>
                    </div>

                    <div class="kiosk-receipt-list" id="confirmReceiptList"></div>

                    <div class="kiosk-receipt-total">
                        <span>Total Points</span>
                        <strong id="confirmReceiptTotalDisplay"></strong>
                    </div>
                </div>
            </div>
            <div class="modal-footer kiosk-confirm-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="confirmCheckoutButton">Complete Checkout</button>
            </div>
        </div>
    </div>
</div>

