
@{
    ViewData["Title"] = "Order History";
}

@{

    var orders = new List<dynamic>
    {
        new {
            OrderId = 1001,
            User = "022001",
            OrderDate = "2026/05/01",
            Total = 12,
            Items = new List<dynamic>
            {
                new { InventoryUPC = 101010100, ItemName = "Canned Black Beans", Category = "Canned Goods", Quantity = 2, Points = 4 },
                new { InventoryUPC = 101010101, ItemName = "White Rice (2 lb)",   Category = "Grains",       Quantity = 1, Points = 3 },
                new { InventoryUPC = 101010102, ItemName = "Peanut Butter",        Category = "Pantry",       Quantity = 1, Points = 5 }
            }
        },
        new {
            OrderId = 1002,
            User = "003032",
            OrderDate = "2026/05/03",
            Total = 7,
            Items = new List<dynamic>
            {
                new { InventoryUPC = 101010103, ItemName = "Pasta (1 lb)",     Category = "Grains",       Quantity = 2, Points = 4 },
                new { InventoryUPC = 101010104, ItemName = "Marinara Sauce",   Category = "Canned Goods", Quantity = 1, Points = 3 }
            }
        },
        new {
            OrderId = 1003,
            User = "004045",
            OrderDate = "2026/05/04",
            Total = 9,
            Items = new List<dynamic>
            {
                new { InventoryUPC = 101010105, ItemName = "Cereal",        Category = "Breakfast", Quantity = 1, Points = 4 },
                new { InventoryUPC = 101010106, ItemName = "Milk (1 gal)",  Category = "Dairy",     Quantity = 1, Points = 5 }
            }
        }
    };
}


<div class="order-history py-4">
    <div class="order-history-header mb-4">
        <div>
            <h1 class="order-history-title">Order History</h1>
            <p class="order-history-subtitle mb-0">
                History of all past orders.
            </p>
        </div>

        <div class="order-search-box">
            <input type="text" id="orderSearch" class="form-control" placeholder="Search order..." onkeyup="searchOrders()" />
        </div>
    </div>

    <div class="order-card">
        <div class="table-responsive">
            <table class="table order-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order Id</th>
                        <th>User Id</th>
                        <th>Date</th>
                        <th>Total Points</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr class="order-row" onclick="toggleOrder(@order.OrderId)">
                            <td>@order.OrderId</td>
                            <td>@order.User</td>
                            <td>@order.OrderDate</td>
                            <td>@order.Total</td>
                        </tr>

                        <tr class="order-detail-row">
                            <td colspan="4">
                                <div class="order-detail-content" id="order-detail-@order.OrderId">
                                    <table class="table order-detail-table mb-0">
                                        <thead>
                                            <tr>
                                                <th>UPC</th>
                                                <th>Item Name</th>
                                                <th>Category</th>
                                                <th>Quantity</th>
                                                <th>Points</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in order.Items)
                                            {
                                                <tr>
                                                    <td>@item.InventoryUPC</td>
                                                    <td>@item.ItemName</td>
                                                    <td>@item.Category</td>
                                                    <td>@item.Quantity</td>
                                                    <td>@item.Points</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>