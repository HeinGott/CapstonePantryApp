@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container">
    <div class="row justify-content-center">
                
        <div class="col-md-6 col-lg-4">
            <h1 class="text-center mb-3">
                <img src="/images/SCC-Logo.png" alt="SCC Logo"
                     style="width:380px; height:90px;" />
            </h1>
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <h2 class="text-center">Register a new account</h2>
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control"
                           placeholder="example@gmail.com"
                           autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <div class="input-group">
                        <input asp-for="Input.Password" class="form-control"
                               id="registerPasswordInput"
                               placeholder="Enter your password"
                               autocomplete="new-password" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="toggleRegisterPasswordButton">
                            Show
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                    <div class="input-group">
                        <input asp-for="Input.ConfirmPassword" class="form-control"
                               id="registerConfirmPasswordInput"
                               placeholder="Re-enter your password"
                               autocomplete="new-password" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                id="toggleRegisterConfirmPasswordButton">
                            Show
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>


                <div class="flex-container">
                    <button id="registerSubmit" type="submit"
                            class="w-100 btn btn-lg btn-primary">
                        Register
                    </button>

                    <a asp-controller="Donor"
                       asp-action="Register"
                       class="w-100 btn btn-lg btn-primary mt-3">
                        Register as Donor
                    </a>
                </div>


            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function wirePasswordToggle(inputId, buttonId) {
            const input = document.getElementById(inputId);
            const button = document.getElementById(buttonId);

            button.addEventListener("click", function () {
                if (input.type === "password") {
                    input.type = "text";
                    button.textContent = "Hide";
                }
                else {
                    input.type = "password";
                    button.textContent = "Show";
                }
            });
        }

        wirePasswordToggle("registerPasswordInput", "toggleRegisterPasswordButton");
        wirePasswordToggle("registerConfirmPasswordInput", "toggleRegisterConfirmPasswordButton");
    </script>
}
