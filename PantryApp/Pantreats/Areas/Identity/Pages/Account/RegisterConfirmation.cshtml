@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="student-card p-4 p-md-5 text-center">
                <h1 class="mb-3">@ViewData["Title"]</h1>
                <p class="student-page-subtitle mb-3">
                    We created your @(Model.AccountType == "student" ? "student" : "donor") account for <strong>@Model.Email</strong>.
                </p>
                <p class="mb-4">
                    Enter the 6-digit code we sent to your email to confirm your account.
                </p>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger text-start" role="alert">
                        @foreach (var error in ModelState.Values.SelectMany(state => state.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="alert alert-light border text-start" role="alert">
                        @Model.StatusMessage
                    </div>
                }

                <form method="post" asp-page-handler="Confirm" id="confirmCodeForm">
                    <input type="hidden" name="email" value="@Model.Email" />
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="accountType" value="@Model.AccountType" />
                    <input type="hidden" name="continueUrl" value="@Model.ContinueUrl" />
                    <input type="hidden" asp-for="Code" id="fullCodeInput" />

                    <div class="d-flex justify-content-center gap-2 mb-4" id="codeBoxes">
                        <input type="text" inputmode="numeric" maxlength="1" class="form-control text-center code-box" style="width: 3rem; font-size: 1.5rem;" autofocus />
                        <input type="text" inputmode="numeric" maxlength="1" class="form-control text-center code-box" style="width: 3rem; font-size: 1.5rem;" />
                        <input type="text" inputmode="numeric" maxlength="1" class="form-control text-center code-box" style="width: 3rem; font-size: 1.5rem;" />
                        <input type="text" inputmode="numeric" maxlength="1" class="form-control text-center code-box" style="width: 3rem; font-size: 1.5rem;" />
                        <input type="text" inputmode="numeric" maxlength="1" class="form-control text-center code-box" style="width: 3rem; font-size: 1.5rem;" />
                        <input type="text" inputmode="numeric" maxlength="1" class="form-control text-center code-box" style="width: 3rem; font-size: 1.5rem;" />
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary btn-lg">Confirm Email</button>
                    </div>
                </form>

                <form method="post" asp-page-handler="Resend" class="mt-3">
                    <input type="hidden" name="email" value="@Model.Email" />
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="accountType" value="@Model.AccountType" />
                    <input type="hidden" name="continueUrl" value="@Model.ContinueUrl" />

                    <button type="submit" class="btn btn-link">Resend Code</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const boxes = Array.from(document.querySelectorAll(".code-box"));
            const fullCodeInput = document.getElementById("fullCodeInput");
            const form = document.getElementById("confirmCodeForm");

            function syncFullCode() {
                fullCodeInput.value = boxes.map(box => box.value).join("");
            }

            boxes.forEach(function (box, index) {
                box.addEventListener("input", function () {
                    box.value = box.value.replace(/[^0-9]/g, "");

                    if (box.value.length === 1 && index < boxes.length - 1) {
                        boxes[index + 1].focus();
                    }

                    syncFullCode();
                });

                box.addEventListener("keydown", function (event) {
                    if (event.key === "Backspace" && box.value === "" && index > 0) {
                        boxes[index - 1].focus();
                    }
                });

                box.addEventListener("paste", function (event) {
                    event.preventDefault();
                    const pasted = (event.clipboardData || window.clipboardData).getData("text").replace(/[^0-9]/g, "");

                    for (let i = 0; i < boxes.length; i++) {
                        boxes[i].value = pasted[i] || "";
                    }

                    syncFullCode();

                    const nextEmptyIndex = boxes.findIndex(function (b) { return b.value === ""; });
                    boxes[nextEmptyIndex === -1 ? boxes.length - 1 : nextEmptyIndex].focus();
                });
            });

            form.addEventListener("submit", syncFullCode);
        })();
    </script>
}