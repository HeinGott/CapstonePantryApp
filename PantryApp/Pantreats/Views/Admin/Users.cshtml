@model List<Pantreats.Models.UserManagerViewModel>

@{
    ViewData["Title"] = "User Manager";
}

<div class="student-page py-4">

    <div class="student-page-header mb-4">
        <h1 class="student-page-title">User Manager</h1>
        <p class="student-page-subtitle">
            Manage user accounts and roles.
        </p>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        var statusType = TempData["StatusType"] as string ?? "success";
        var toastClass = statusType == "error" ? "text-bg-danger" : "text-bg-success";
        var toastTitle = statusType == "error" ? "Action failed" : "Success";

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="adminStatusToast" class="toast @toastClass border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header">
                    <strong class="me-auto">@toastTitle</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    @statusMessage
                </div>
            </div>
        </div>
    }

    <div class="student-card">
        <table class="table student-table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <tr class="user-row"
                        role="button"
                        tabindex="0"
                        onclick="window.location='@Url.Action("UserEdit", "Admin", new { id = user.UserId })'"
                        onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); this.click(); }">
                        <td>@user.Email</td>
                        <td>@user.Role</td>
                        <td onclick="event.stopPropagation();">
                            <form asp-action="EditUser" asp-controller="Admin" method="post" style="display:flex; gap:8px;">
                                <input type="hidden" name="userID" value="@user.UserId"/>
                                <select name="newRole" class="form-select form-select-sm">
                                   <option value="" disabled selected="@(string.IsNullOrEmpty(user.RoleValue) ? "selected" : null)">Select a role...</option>
                                   <option value="Admin" selected="@(user.RoleValue == "Admin" ? "selected" : null)">Admin</option>
                                   <option value="Students" selected="@(user.RoleValue == "Students" ? "selected" : null)">Student</option>
                                   <option value="Volunteers" selected="@(user.RoleValue == "Volunteers" ? "selected" : null)">Volunteer</option>
                                   <option value="Donors" selected="@(user.RoleValue == "Donors" ? "selected" : null)">Donor</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">Save</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toastElement = document.getElementById("adminStatusToast");
            if (!toastElement) {
                return;
            }

            const toast = new bootstrap.Toast(toastElement, {
                delay: 3500
            });

            toast.show();
        });
    </script>
}

<style>
    .toast-container {
        z-index: 1085;
    }

    .user-row {
        cursor: pointer;
        transition: background-color 0.18s ease, box-shadow 0.18s ease;
    }

    .user-row:hover {
        background-color: #f4f7fc;
        box-shadow: inset 4px 0 0 var(--pantreats-green);
    }

    .student-table tbody tr.user-row:hover > td {
        background-color: #f4f7fc;
        color: #111827;
    }

    .user-row:focus-visible {
        outline: 2px solid rgba(13, 110, 253, 0.35);
        outline-offset: -2px;
    }
</style>
