@model Pantreats.Models.Donor

@{
    ViewData["Title"] = "Edit Donor";
}

<div class="vendor-edit-page py-4">

    <div class="mb-3">
        <a asp-controller="Donor"
               asp-action="Details"
               asp-route-id="@Model.DonorID"
               class="btn student-back-btn">
            ← Back to Donor
        </a>
    </div>

    <div class="student-card">

        <h1 class="mb-2">Edit Donor</h1>
        <p class="student-page-subtitle mb-4">
            Update donor information.
        </p>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="DonorID" />

            <div class="mb-3">
                <label class="form-label">Donor Name</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
            </div>

            <hr class="my-4" />

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

                <!-- save -->
                <button type="submit" class="inventory-edit-btn">
                    Save Changes
                </button>

                <!-- delete trigger -->
                <button type="button"
                        class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteDonorModal">
                    Delete Donor
                </button>

            </div>

        </form>

    </div>

</div>

<!-- delete modal -->
<div class="modal fade"
     id="deleteDonorModal"
     tabindex="-1"
     aria-labelledby="deleteDonorModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="deleteDonorModalLabel">
                    Delete Donor
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                </button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete
                <strong>@Model.Name</strong>?
            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn app-btn app-btn-primary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <form asp-controller="Donor"
                      asp-action="Delete"
                      asp-route-id="@Model.DonorID"
                      method="post">

                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>

                </form>

            </div>

        </div>
    </div>

</div>
