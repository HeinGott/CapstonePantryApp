@{
    ViewData["Title"] = "Students";

    var students = new List<dynamic>
    {
        new { Id = 1, Name = "Jimmy Hendrix", StudentNumber = "10001" },
        new { Id = 2, Name = "Sarah Johnson", StudentNumber = "10002" },
        new { Id = 3, Name = "Michael Brown", StudentNumber = "10003" },
        new { Id = 4, Name = "Emily Davis", StudentNumber = "10004" },
        new { Id = 5, Name = "Chris Wilson", StudentNumber = "10005" }
    };
}

<div class="student-page py-4">

    <div class="student-page-header mb-4">
        <div>
            <h1 class="student-page-title mb-1">Students</h1>
            <p class="student-page-subtitle mb-0">
                View student records and open a student profile to see more details.
            </p>
        </div>

        <div class="student-search-box">
            <input type="text" id="studentSearch" class="form-control" placeholder="Search student..." onkeyup="searchStudents()" />
        </div>
    </div>

    <div class="student-card">
        <div class="table-responsive">
            <table class="table student-table align-middle mb-0" id="studentTable">
                <thead>
                    <tr>
                        <th onclick="sortTable('studentTable', 0, this)">Student Name</th>
                        <th onclick="sortTable('studentTable', 1, this)">Student ID Number</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var student in students)
                    {
                        <tr class="student-row" onclick="goToStudent(@student.Id)">
                            <td>@student.Name</td>
                            <td>@student.StudentNumber</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function goToStudent(id) {
            window.location.href = '/Student/Details/' + id;
        }

        function searchStudents() {
            let input = document.getElementById("studentSearch");
            let filter = input.value.toLowerCase();
            let table = document.getElementById("studentTable");
            let rows = table.getElementsByTagName("tr");

            for (let i = 1; i < rows.length; i++) {
                let rowText = rows[i].innerText.toLowerCase();

                if (rowText.includes(filter)) {
                    rows[i].style.display = "";
                }
                else {
                    rows[i].style.display = "none";
                }
            }
        }

        function sortTable(tableId, columnNumber, header) {
            let table = document.getElementById(tableId);
            let tbody = table.tBodies[0];
            let rows = Array.from(tbody.rows);
            let currentSort = header.getAttribute("data-sort");

            let newSort = "asc";

            if (currentSort === "asc") {
                newSort = "desc";
            }

            let headers = table.querySelectorAll("th");

            headers.forEach(function (th) {
                th.removeAttribute("data-sort");
            });

            header.setAttribute("data-sort", newSort);

            rows.sort(function (a, b) {
                let firstValue = a.cells[columnNumber].innerText.trim();
                let secondValue = b.cells[columnNumber].innerText.trim();

                // sort student name by last name
                if (columnNumber === 0) {
                    let firstLastName = firstValue.split(" ").slice(-1)[0].toLowerCase();
                    let secondLastName = secondValue.split(" ").slice(-1)[0].toLowerCase();

                    if (firstLastName < secondLastName) {
                        return newSort === "asc" ? -1 : 1;
                    }

                    if (firstLastName > secondLastName) {
                        return newSort === "asc" ? 1 : -1;
                    }

                    return 0;
                }

                let firstLower = firstValue.toLowerCase();
                let secondLower = secondValue.toLowerCase();

                let firstNumber = parseFloat(firstLower);
                let secondNumber = parseFloat(secondLower);

                if (!isNaN(firstNumber) && !isNaN(secondNumber)) {
                    return newSort === "asc" ? firstNumber - secondNumber : secondNumber - firstNumber;
                }

                if (firstLower < secondLower) {
                    return newSort === "asc" ? -1 : 1;
                }

                if (firstLower > secondLower) {
                    return newSort === "asc" ? 1 : -1;
                }

                return 0;
            });

            rows.forEach(function (row) {
                tbody.appendChild(row);
            });
        }
    </script>
}