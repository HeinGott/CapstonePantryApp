@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout !=  null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<h1 class="manage-page-title">Manage your account</h1>

<div class="manage-page-shell">
    <h2 class="manage-page-subtitle">Change your account settings</h2>
    <hr />
    <div class="row manage-page-grid">
        <div class="col-md-3 manage-nav-column">
            <partial name="_ManageNav" />
        </div>
        <div class="col-md-9 manage-content-column">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
