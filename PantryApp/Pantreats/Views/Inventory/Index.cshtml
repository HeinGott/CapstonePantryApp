@model List<Pantreats.Models.Inventory>

@{
    ViewData["Title"] = "Inventory";
    var subcategories = Model.Select(x => x.Subcategory)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();

    string GetSubcategoryIconPath(string subcategory) => subcategory.ToLowerInvariant() switch
    {
        var value when value.Contains("bean") => "~/images/subcategories/bean-green-bean-snap-svgrepo-com.svg",
        var value when value.Contains("grocery") || value.Contains("cereal") || value.Contains("pantry") => "~/images/subcategories/groceries-svgrepo-com.svg",
        var value when value.Contains("pasta") => "~/images/subcategories/pasta-svgrepo-com.svg",
        var value when value.Contains("poultry") || value.Contains("chicken") || value.Contains("meat") => "~/images/subcategories/poultry-leg-svgrepo-com.svg",
        var value when value.Contains("snack") => "~/images/subcategories/snacks-popcorn-svgrepo-com.svg",
        var value when value.Contains("soup") => "~/images/subcategories/soup-svgrepo-com.svg",
        var value when value.Contains("tomato") => "~/images/subcategories/tomato-svgrepo-com.svg",
        var value when value.Contains("toothpaste") || value.Contains("dental") || value.Contains("toiletry") || value.Contains("hygiene") || value.Contains("oral") => "~/images/subcategories/toothpaste-health-care-svgrepo-com.svg",
        var value when value.Contains("vegetable") || value.Contains("produce") || value.Contains("salad") => "~/images/subcategories/vegetables-salad-svgrepo-com.svg",
        _ => string.Empty
    };

    string GetSubcategoryDisplayName(string subcategory) =>
        string.Equals(subcategory, "Pantry - Other", StringComparison.OrdinalIgnoreCase) ? "Other" : subcategory;
}

<style>
    .inventory-subcategory-strip {
        display: flex;
        flex-wrap: nowrap;
        gap: 1rem;
        overflow-x: auto;
        overflow-y: hidden;
        padding: 0;
        margin: 0;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }

    .inventory-subcategory-strip::-webkit-scrollbar {
        display: none;
    }

    .inventory-subcategory-rail {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .inventory-subcategory-strip-wrap {
        min-width: 0;
        flex: 1 1 auto;
        overflow: hidden;
    }

    .inventory-subcategory-card {
        border: 0;
        background: transparent;
        padding: .35rem .25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .55rem;
        flex: 0 0 96px;
        color: #183153;
        transition: transform .15s ease, opacity .15s ease;
    }

    .inventory-subcategory-next {
        width: 36px;
        height: 36px;
        border: 1px solid rgba(16, 47, 97, 0.08);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        color: rgba(24, 49, 83, 0.58);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        box-shadow: 0 4px 12px rgba(16, 47, 97, 0.05);
        transition: transform .15s ease, box-shadow .15s ease, opacity .15s ease, color .15s ease, border-color .15s ease;
    }

    .inventory-subcategory-next:hover:not(:disabled) {
        color: rgba(24, 49, 83, 0.78);
        border-color: rgba(16, 47, 97, 0.14);
        box-shadow: 0 6px 14px rgba(16, 47, 97, 0.08);
    }

    .inventory-subcategory-next:disabled {
        opacity: 0;
        cursor: default;
        box-shadow: none;
        pointer-events: none;
    }

    .inventory-subcategory-card:hover {
        transform: translateY(-2px);
        opacity: .92;
    }

    .inventory-subcategory-card.active .inventory-subcategory-icon {
        background: #183153;
        color: #fff;
        box-shadow: 0 10px 20px rgba(24, 49, 83, .18);
    }

    .inventory-subcategory-card.active .inventory-subcategory-label {
        color: #183153;
    }

    .inventory-subcategory-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #e8f1df;
        overflow: hidden;
        padding: .7rem;
    }

    .inventory-subcategory-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: brightness(0) saturate(100%) invert(49%) sepia(64%) saturate(563%) hue-rotate(46deg) brightness(96%) contrast(88%);
    }

    .inventory-subcategory-fallback {
        color: #74a833;
        font-size: 1.35rem;
    }

    .inventory-subcategory-label {
        font-size: .92rem;
        font-weight: 600;
        line-height: 1.2;
        text-align: center;
    }

    .inventory-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .inventory-toolbar-search {
        flex: 1 1 380px;
    }

    .inventory-toolbar-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .inventory-delete-modal {
        position: fixed;
        inset: 0;
        background: rgba(24, 49, 83, .38);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        z-index: 1100;
    }

    .inventory-delete-modal.open {
        display: flex;
    }

    .inventory-delete-dialog {
        width: min(100%, 420px);
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 24px 60px rgba(24, 49, 83, .18);
        padding: 1.5rem;
    }

    .inventory-delete-badge {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: #eef3fb;
        color: #183153;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    .inventory-delete-title {
        margin: 0 0 .45rem;
        color: #183153;
        font-size: 1.25rem;
        font-weight: 700;
    }

    .inventory-delete-copy {
        margin: 0 0 1.25rem;
        color: #51627d;
        line-height: 1.5;
    }

    .inventory-delete-actions {
        display: flex;
        justify-content: flex-end;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .inventory-toast {
        position: fixed;
        right: 1.5rem;
        bottom: 1.5rem;
        z-index: 1200;
        min-width: 280px;
        max-width: 360px;
        background: #183153;
        color: #fff;
        border-radius: 18px;
        box-shadow: 0 18px 42px rgba(24, 49, 83, .22);
        padding: .95rem 1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        opacity: 0;
        transform: translateY(12px);
        pointer-events: none;
        transition: opacity .25s ease, transform .25s ease;
    }

    .inventory-toast.show {
        opacity: 1;
        transform: translateY(0);
    }

    .inventory-toast-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: rgba(255, 255, 255, .12);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
    }

    .inventory-toast-copy {
        margin: 0;
        line-height: 1.4;
        font-size: .95rem;
    }
</style>

<div class="donor-page py-4">

    <div class="donor-page-header inventory-page-header mb-4">
        <div class="inventory-page-intro">
            <h1 class="donor-page-title mb-1">Inventory</h1>
            <p class="donor-page-subtitle mb-0">
                View and manage all pantry inventory items.
            </p>
        </div>

        <div class="student-card inventory-card">

            <div class="inventory-subcategory-rail">
                <button type="button"
                        class="inventory-subcategory-next"
                        id="inventorySubcategoryPrevious"
                        aria-label="Show previous inventory categories">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <div class="inventory-subcategory-strip-wrap">
                    <div class="inventory-subcategory-strip" id="inventorySubcategoryStrip">
                        <button type="button"
                                class="inventory-subcategory-card active"
                                data-subcategory-filter="">
                            <span class="inventory-subcategory-icon">
                                <img src="@Url.Content("~/images/subcategories/groceries-svgrepo-com.svg")" alt="All Items" />
                            </span>
                            <span class="inventory-subcategory-label">All Items</span>
                        </button>

                        @foreach (var subcategory in subcategories)
                        {
                            var iconPath = GetSubcategoryIconPath(subcategory);
                            var displayName = GetSubcategoryDisplayName(subcategory);
                            <button type="button"
                                    class="inventory-subcategory-card"
                                    data-subcategory-filter="@subcategory">
                                <span class="inventory-subcategory-icon">
                                    @if (!string.IsNullOrWhiteSpace(iconPath))
                                    {
                                        <img src="@Url.Content(iconPath)" alt="@displayName" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-tag-fill inventory-subcategory-fallback"></i>
                                    }
                                </span>
                                <span class="inventory-subcategory-label">@displayName</span>
                            </button>
                        }
                    </div>
                </div>

                <button type="button"
                        class="inventory-subcategory-next"
                        id="inventorySubcategoryNext"
                        aria-label="Show more inventory categories">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>

            <div class="inventory-toolbar">
                <div class="inventory-toolbar-search">
                    <div class="inventory-search-scan">
                        <span class="inventory-scan-trigger" aria-hidden="true">
                            <i class="bi bi-upc-scan"></i>
                        </span>

                        <input type="text"
                               id="searchText"
                               class="form-control inventory-search-input"
                               autofocus
                               autocomplete="off"
                               placeholder="Scan UPC or search name, brand, subcategory..." />
                    </div>
                </div>

                <div class="inventory-toolbar-actions">
                    <div class="form-check mb-0">
                        <input class="form-check-input"
                               type="checkbox"
                               id="inStockOnly">

                        <label class="form-check-label" for="inStockOnly">
                            Show in-stock only
                        </label>
                    </div>

                    <a asp-controller="Inventory"
                       asp-action="Create"
                       class="btn inventory-edit-btn">
                        <i class="bi bi-plus-lg"></i> Add Item
                    </a>
                </div>
            </div>

            <div class="table-responsive">

                <table class="table student-table inventory-table align-middle mb-0" id="inventoryTable">

                    <thead>
                        <tr>
                            <th onclick="sortTable('inventoryTable', 0, this)">UPC</th>
                            <th onclick="sortTable('inventoryTable', 1, this)">Name</th>
                            <th onclick="sortTable('inventoryTable', 2, this)">Brand</th>
                            <th onclick="sortTable('inventoryTable', 3, this)">Subcategory</th>
                            <th onclick="sortTable('inventoryTable', 4, this)">Unit Size</th>
                            <th onclick="sortTable('inventoryTable', 5, this)">Quantity</th>
                            <th onclick="sortTable('inventoryTable', 6, this)">Points</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr class="student-row inventory-row" data-edit-url="@Url.Action("Edit", "Inventory", new { id = item.ItemId })">
                                <td><span class="inventory-cell-text inventory-cell-text-single">@item.UPC</span></td>
                                <td><span class="inventory-cell-text inventory-name-cell-text">@item.ItemName</span></td>
                                <td><span class="inventory-cell-text">@item.BrandName</span></td>
                                <td><span class="inventory-cell-text inventory-cell-text-single">@item.Subcategory</span></td>
                                <td><span class="inventory-cell-text inventory-cell-text-single">@item.UnitSize</span></td>
                                <td><span class="inventory-cell-text inventory-cell-text-single">@item.Quantity</span></td>
                                <td><span class="inventory-cell-text inventory-cell-text-single">@item.Points</span></td>

                                <td class="inventory-actions-cell">
                                    <div class="inventory-actions-group">
                                        <a asp-controller="Inventory"
                                           asp-action="Edit"
                                           asp-route-id="@item.ItemId"
                                           class="inventory-edit-btn">
                                            Edit
                                        </a>

                                        <form asp-controller="Inventory"
                                              asp-action="DeleteConfirmed"
                                              asp-route-id="@item.ItemId"
                                              method="post"
                                              style="display:inline;"
                                              class="inventory-delete-form"
                                              data-item-name="@item.ItemName">

                                            <button type="submit" class="inventory-delete-btn">
                                                Delete
                                            </button>

                                        </form>
                                    </div>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <div class="inventory-delete-modal" id="inventoryDeleteModal" aria-hidden="true">
            <div class="inventory-delete-dialog" role="dialog" aria-modal="true" aria-labelledby="inventoryDeleteTitle">
                <div class="inventory-delete-badge">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <h2 class="inventory-delete-title" id="inventoryDeleteTitle">Delete inventory item?</h2>
                <p class="inventory-delete-copy" id="inventoryDeleteCopy">
                    This item will be removed from the pantry inventory list.
                </p>
                <div class="inventory-delete-actions">
                    <button type="button" class="btn btn-outline-secondary" id="inventoryDeleteCancel">Cancel</button>
                    <button type="button" class="btn inventory-delete-btn" id="inventoryDeleteConfirm">Delete</button>
                </div>
            </div>
        </div>

    </div>

</div>

@if (TempData["InventoryToast"] is string toastMessage)
{
    <div class="inventory-toast" id="inventoryToast" role="status" aria-live="polite">
        <span class="inventory-toast-icon">
            <i class="bi bi-check2-circle"></i>
        </span>
        <p class="inventory-toast-copy">@toastMessage</p>
    </div>
}

@section Scripts {
    <script>
        function sortTable(tableId, columnNumber, header) {
            let table = document.getElementById(tableId);
            let tbody = table.tBodies[0];
            let rows = Array.from(tbody.rows);
            let currentSort = header.getAttribute("data-sort");

            let newSort = "asc";

            if (currentSort === "asc") {
                newSort = "desc";
            }

            let headers = table.querySelectorAll("th");

            headers.forEach(function (th) {
                th.removeAttribute("data-sort");
            });

            header.setAttribute("data-sort", newSort);

            rows.sort(function (a, b) {
                let firstValue = a.cells[columnNumber].innerText.trim();
                let secondValue = b.cells[columnNumber].innerText.trim();

                let firstLower = firstValue.toLowerCase();
                let secondLower = secondValue.toLowerCase();

                let firstNumber = parseFloat(firstLower);
                let secondNumber = parseFloat(secondLower);

                if (!isNaN(firstNumber) && !isNaN(secondNumber)) 
                {
                    return newSort === "asc" ? firstNumber - secondNumber : secondNumber - firstNumber;
                }

                if (firstLower < secondLower) 
                {
                    return newSort === "asc" ? -1 : 1;
                }

                if (firstLower > secondLower) 
                {
                    return newSort === "asc" ? 1 : -1;
                }

                return 0;
            });

            rows.forEach(function (row) {
                tbody.appendChild(row);
            });
        }


        //Inventory search/filter scripts -- Trevor
        const searchText = document.getElementById("searchText");
        const inStockOnly = document.getElementById("inStockOnly");
        const subcategoryButtons = document.querySelectorAll("[data-subcategory-filter]");
        const subcategoryStrip = document.getElementById("inventorySubcategoryStrip");
        const subcategoryPreviousButton = document.getElementById("inventorySubcategoryPrevious");
        const subcategoryNextButton = document.getElementById("inventorySubcategoryNext");
        const deleteModal = document.getElementById("inventoryDeleteModal");
        const deleteCancelButton = document.getElementById("inventoryDeleteCancel");
        const deleteConfirmButton = document.getElementById("inventoryDeleteConfirm");
        const deleteCopy = document.getElementById("inventoryDeleteCopy");
        const deleteForms = document.querySelectorAll(".inventory-delete-form");
        const inventoryToast = document.getElementById("inventoryToast");
        let activeSubcategory = "";
        let pendingDeleteForm = null;

        function filterInventoryTable()
        {
            let searchValue = searchText.value.toLowerCase();
            let subcategoryValue = activeSubcategory.toLowerCase();
            let showStockOnly = inStockOnly.checked;

            let rows = document.querySelectorAll("#inventoryTable tbody tr");

            rows.forEach(function (row)
            {
                let upc = row.cells[0].innerText.toLowerCase();
                let name = row.cells[1].innerText.toLowerCase();
                let brand = row.cells[2].innerText.toLowerCase();
                let subcategory = row.cells[3].innerText.toLowerCase();
                let quantity = parseInt(row.cells[5].innerText);

                let matchesSearch =
                    upc.includes(searchValue) ||
                    name.includes(searchValue) ||
                    brand.includes(searchValue) ||
                    subcategory.includes(searchValue);

                let matchesCategory =
                    subcategoryValue === "" ||
                    subcategory === subcategoryValue;

                let matchesStock =
                    !showStockOnly ||
                    quantity > 0;

                row.style.display =
                    matchesSearch &&
                    matchesCategory &&
                    matchesStock
                        ? ""
                        : "none";
            });
        }

        searchText.addEventListener("input", filterInventoryTable);
        inStockOnly.addEventListener("change", filterInventoryTable);

        subcategoryButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                activeSubcategory = button.dataset.subcategoryFilter || "";

                subcategoryButtons.forEach(function (item) {
                    item.classList.toggle("active", item === button);
                });

                filterInventoryTable();
            });
        });

        function updateSubcategoryNavState() {
            if (!subcategoryStrip || !subcategoryPreviousButton || !subcategoryNextButton) {
                return;
            }

            const maxScrollLeft = subcategoryStrip.scrollWidth - subcategoryStrip.clientWidth;
            const hasOverflow = maxScrollLeft > 8;
            const atStart = subcategoryStrip.scrollLeft <= 8;
            const atEnd = subcategoryStrip.scrollLeft >= maxScrollLeft - 8;

            subcategoryPreviousButton.hidden = !hasOverflow;
            subcategoryNextButton.hidden = !hasOverflow;
            subcategoryPreviousButton.disabled = atStart;
            subcategoryNextButton.disabled = atEnd;
        }

        if (subcategoryStrip && subcategoryPreviousButton && subcategoryNextButton) {
            subcategoryPreviousButton.addEventListener("click", function () {
                const scrollAmount = Math.max(220, Math.floor(subcategoryStrip.clientWidth * 0.72));

                subcategoryStrip.scrollBy({
                    left: -scrollAmount,
                    behavior: "smooth"
                });
            });

            subcategoryNextButton.addEventListener("click", function () {
                const scrollAmount = Math.max(220, Math.floor(subcategoryStrip.clientWidth * 0.72));

                subcategoryStrip.scrollBy({
                    left: scrollAmount,
                    behavior: "smooth"
                });
            });

            subcategoryStrip.addEventListener("scroll", updateSubcategoryNavState);
            window.addEventListener("resize", updateSubcategoryNavState);
            updateSubcategoryNavState();
        }

        document.querySelectorAll(".inventory-row").forEach(function (row) {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, form")) {
                    return;
                }

                const editUrl = row.dataset.editUrl;

                if (editUrl) {
                    window.location.href = editUrl;
                }
            });
        });

        deleteForms.forEach(function (form) {
            form.addEventListener("submit", function (event) {
                event.preventDefault();
                pendingDeleteForm = form;

                const itemName = form.dataset.itemName || "this inventory item";
                deleteCopy.textContent = `Delete ${itemName}? This will remove it from the pantry inventory list.`;
                deleteModal.classList.add("open");
                deleteModal.setAttribute("aria-hidden", "false");
            });
        });

        function closeDeleteModal() {
            deleteModal.classList.remove("open");
            deleteModal.setAttribute("aria-hidden", "true");
            pendingDeleteForm = null;
        }

        deleteCancelButton.addEventListener("click", closeDeleteModal);

        deleteConfirmButton.addEventListener("click", function () {
            if (pendingDeleteForm) {
                pendingDeleteForm.submit();
            }
        });

        deleteModal.addEventListener("click", function (event) {
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && deleteModal.classList.contains("open")) {
                closeDeleteModal();
            }
        });

        if (inventoryToast) {
            requestAnimationFrame(function () {
                inventoryToast.classList.add("show");
            });

            setTimeout(function () {
                inventoryToast.classList.remove("show");
            }, 2800);
        }
    </script>


}
