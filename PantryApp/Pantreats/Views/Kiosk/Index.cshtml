@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const lookupPanel = document.getElementById("kioskLookupPanel");
            const checkoutPanel = document.getElementById("kioskCheckoutPanel");
            const completePanel = document.getElementById("kioskCompletePanel");
            const studentIdInput = document.getElementById("studentIdInput");
            const studentLookupButton = document.getElementById("studentLookupButton");
            const studentNameDisplay = document.getElementById("studentNameDisplay");
            const studentIdDisplay = document.getElementById("studentIdDisplay");
            const lookupStatus = document.getElementById("lookupStatus");
            const itemUpcInput = document.getElementById("itemUpcInput");
            const itemLookupButton = document.getElementById("itemLookupButton");
            const itemStatus = document.getElementById("itemStatus");
            const checkoutStatus = document.getElementById("checkoutStatus");
            const cartTableWrap = document.getElementById("cartTableWrap");
            const cartTableBody = document.getElementById("cartTableBody");
            const emptyCartState = document.getElementById("emptyCartState");
            const cartCountDisplay = document.getElementById("cartCountDisplay");
            const totalPointsDisplay = document.getElementById("totalPointsDisplay");
            const checkoutButton = document.getElementById("checkoutButton");
            const startOverButton = document.getElementById("startOverButton");
            const confirmStudentDisplay = document.getElementById("confirmStudentDisplay");
            const confirmItemCountDisplay = document.getElementById("confirmItemCountDisplay");
            const confirmTotalPointsDisplay = document.getElementById("confirmTotalPointsDisplay");
            const confirmReceiptTotalDisplay = document.getElementById("confirmReceiptTotalDisplay");
            const confirmReceiptList = document.getElementById("confirmReceiptList");
            const confirmCheckoutButton = document.getElementById("confirmCheckoutButton");
            const checkoutConfirmModalElement = document.getElementById("checkoutConfirmModal");
            const checkoutConfirmModal = new bootstrap.Modal(checkoutConfirmModalElement);
            const completeOrderNumber = document.getElementById("completeOrderNumber");
            const completeOrderDate = document.getElementById("completeOrderDate");

            const state = {
                student: null,
                cart: new Map(),
                completeTimeoutId: null
            };

            function setStatus(element, message, type) {
                element.textContent = message || "";
                element.className = "kiosk-status";

                if (message && type) {
                    element.classList.add(`is-${type}`);
                }
            }

            function focusLookup() {
                studentIdInput.focus();
                studentIdInput.select();
            }

            function focusItemScan() {
                itemUpcInput.focus();
                itemUpcInput.select();
            }

            function resetKiosk(message, type) {
                if (state.completeTimeoutId) {
                    window.clearTimeout(state.completeTimeoutId);
                    state.completeTimeoutId = null;
                }

                state.student = null;
                state.cart.clear();
                studentIdInput.value = "";
                itemUpcInput.value = "";

                lookupPanel.classList.remove("d-none");
                checkoutPanel.classList.add("d-none");
                completePanel.classList.add("d-none");

                renderCart();
                setStatus(itemStatus, "", "");
                setStatus(checkoutStatus, "", "");
                setStatus(lookupStatus, message || "", type || "");
                focusLookup();
            }

            function formatOrderDate(value) {
                const parsedDate = new Date(value);
                if (Number.isNaN(parsedDate.getTime())) {
                    return value;
                }

                return parsedDate.toLocaleDateString("en-US", {
                    month: "numeric",
                    day: "numeric",
                    year: "numeric"
                });
            }

            function showCompletionScreen(orderId, orderDate) {
                lookupPanel.classList.add("d-none");
                checkoutPanel.classList.add("d-none");
                completePanel.classList.remove("d-none");

                completeOrderNumber.textContent = orderId ? `#${orderId}` : "";
                completeOrderDate.textContent = formatOrderDate(orderDate);

                state.completeTimeoutId = window.setTimeout(function () {
                    resetKiosk();
                }, 10000);
            }

            function renderCart() {
                const items = Array.from(state.cart.values());
                const totalQuantity = items.reduce((sum, item) => sum + item.quantity, 0);
                const totalPoints = items.reduce((sum, item) => sum + (item.points * item.quantity), 0);

                cartTableBody.innerHTML = "";

                items.forEach(function (item) {
                    const row = document.createElement("tr");
                    row.innerHTML = `
                        <td>
                            <span class="kiosk-item-name">${item.itemName}</span>
                            <span class="kiosk-item-brand">${item.brandName || ""}</span>
                        </td>
                        <td>${item.upc}</td>
                        <td>${item.quantity}</td>
                        <td>${item.points}</td>
                        <td class="text-end">${item.points * item.quantity}</td>
                        <td class="text-end">
                            <div class="kiosk-quantity-controls">
                                <button type="button" class="btn btn-outline-secondary btn-sm kiosk-quantity-button" data-upc="${item.upc}" data-action="decrement" aria-label="Remove one ${item.itemName}">
                                    -
                                </button>
                                <span class="kiosk-quantity-value">${item.quantity}</span>
                                <button type="button" class="btn btn-outline-secondary btn-sm kiosk-quantity-button" data-upc="${item.upc}" data-action="increment" aria-label="Add one ${item.itemName}">
                                    +
                                </button>
                            </div>
                        </td>
                    `;

                    cartTableBody.appendChild(row);
                });

                cartCountDisplay.textContent = `${totalQuantity} ${totalQuantity === 1 ? "item" : "items"}`;
                totalPointsDisplay.textContent = totalPoints.toString();
                checkoutButton.disabled = items.length === 0;

                emptyCartState.classList.toggle("d-none", items.length > 0);
                cartTableWrap.classList.toggle("d-none", items.length === 0);
            }

            function getCartSummary() {
                const items = Array.from(state.cart.values());

                return {
                    totalQuantity: items.reduce((sum, item) => sum + item.quantity, 0),
                    totalPoints: items.reduce((sum, item) => sum + (item.points * item.quantity), 0)
                };
            }

            async function postJson(url, payload) {
                const response = await fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenInput.value
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || "Request failed.");
                }

                return data;
            }

            async function lookupStudent() {
                const studentId = studentIdInput.value.trim();
                if (!studentId) {
                    setStatus(lookupStatus, "Enter a student ID number to continue.", "error");
                    focusLookup();
                    return;
                }

                setStatus(lookupStatus, "Looking up student account...", "info");

                try {
                    const data = await postJson("/kiosk/student/lookup", { studentId });

                    state.student = {
                        studentId: data.studentId,
                        fullName: data.fullName
                    };

                    studentNameDisplay.textContent = data.fullName;
                    studentIdDisplay.textContent = `Student ID: ${data.studentId}`;

                    lookupPanel.classList.add("d-none");
                    checkoutPanel.classList.remove("d-none");

                    setStatus(lookupStatus, "", "");
                    setStatus(itemStatus, "Student confirmed. Scan the first item.", "success");
                    setStatus(checkoutStatus, "", "");
                    renderCart();
                    focusItemScan();
                } catch (error) {
                    setStatus(lookupStatus, error.message, "error");
                    focusLookup();
                }
            }

            async function addItem() {
                const upc = itemUpcInput.value.trim();
                if (!upc) {
                    setStatus(itemStatus, "Scan an item barcode to continue.", "error");
                    focusItemScan();
                    return;
                }

                setStatus(itemStatus, "Adding item...", "info");

                try {
                    const data = await postJson("/kiosk/item/lookup", { upc });
                    const item = data.item;
                    const existingItem = state.cart.get(item.upc);

                    if (existingItem && existingItem.quantity >= item.quantity) {
                        setStatus(itemStatus, `Only ${item.quantity} ${item.itemName} ${item.quantity === 1 ? "is" : "are"} available right now.`, "error");
                        focusItemScan();
                        return;
                    }

                    if (existingItem) {
                        existingItem.quantity += 1;
                    } else {
                        state.cart.set(item.upc, {
                            upc: item.upc,
                            itemName: item.itemName,
                            brandName: item.brandName,
                            points: item.points,
                            availableQuantity: item.quantity,
                            quantity: 1
                        });
                    }

                    itemUpcInput.value = "";
                    renderCart();
                    setStatus(itemStatus, `${item.itemName} added to checkout.`, "success");
                    setStatus(checkoutStatus, "", "");
                    focusItemScan();
                } catch (error) {
                    setStatus(itemStatus, error.message, "error");
                    focusItemScan();
                }
            }

            function openCheckoutConfirmation() {
                if (!state.student) {
                    resetKiosk("Student session expired. Start again.", "error");
                    return;
                }

                const items = Array.from(state.cart.values());
                const summary = getCartSummary();
                if (summary.totalQuantity === 0) {
                    setStatus(checkoutStatus, "Add at least one item first.", "error");
                    focusItemScan();
                    return;
                }

                confirmStudentDisplay.textContent = `${state.student.fullName} (${state.student.studentId})`;
                confirmItemCountDisplay.textContent = `${summary.totalQuantity} ${summary.totalQuantity === 1 ? "item" : "items"}`;
                confirmTotalPointsDisplay.textContent = summary.totalPoints.toString();
                confirmReceiptTotalDisplay.textContent = summary.totalPoints.toString();
                confirmReceiptList.innerHTML = "";

                items.forEach(function (item) {
                    const row = document.createElement("div");
                    row.className = "kiosk-receipt-row";
                    row.innerHTML = `
                        <div class="kiosk-receipt-item">
                            <strong>${item.itemName}</strong>
                            <span>${item.upc}</span>
                            <span>${item.quantity} x ${item.points} point${item.points === 1 ? "" : "s"}</span>
                        </div>
                        <div class="kiosk-receipt-points">${item.quantity * item.points}</div>
                    `;

                    confirmReceiptList.appendChild(row);
                });

                checkoutConfirmModal.show();
            }

            async function completeCheckout() {
                if (!state.student) {
                    resetKiosk("Student session expired. Start again.", "error");
                    return;
                }

                const upcs = [];

                state.cart.forEach(function (item) {
                    for (let i = 0; i < item.quantity; i += 1) {
                        upcs.push(item.upc);
                    }
                });

                if (upcs.length === 0) {
                    setStatus(checkoutStatus, "Add at least one item first.", "error");
                    focusItemScan();
                    return;
                }

                checkoutButton.disabled = true;
                confirmCheckoutButton.disabled = true;
                setStatus(checkoutStatus, "Completing checkout...", "info");

                try {
                    const data = await postJson("/kiosk/checkout", {
                        studentId: state.student.studentId.toString(),
                        upcs
                    });

                    checkoutConfirmModal.hide();
                    showCompletionScreen(data.orderId, data.orderDate);
                } catch (error) {
                    checkoutButton.disabled = false;
                    confirmCheckoutButton.disabled = false;
                    renderCart();
                    setStatus(checkoutStatus, error.message, "error");
                    focusItemScan();
                }
            }

            studentLookupButton.addEventListener("click", lookupStudent);
            itemLookupButton.addEventListener("click", addItem);
            checkoutButton.addEventListener("click", openCheckoutConfirmation);
            confirmCheckoutButton.addEventListener("click", completeCheckout);
            startOverButton.addEventListener("click", function () {
                resetKiosk("Checkout cleared. Ready for the next student.", "info");
            });

            checkoutConfirmModalElement.addEventListener("hidden.bs.modal", function () {
                confirmCheckoutButton.disabled = false;
            });

            studentIdInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    lookupStudent();
                }
            });

            itemUpcInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    addItem();
                }
            });

            cartTableBody.addEventListener("click", function (event) {
                const button = event.target.closest("[data-upc]");
                if (!button) {
                    return;
                }

                const upc = button.getAttribute("data-upc");
                const action = button.getAttribute("data-action");
                const item = state.cart.get(upc);

                if (!item || !action) {
                    return;
                }

                if (action === "increment") {
                    if (item.quantity >= item.availableQuantity) {
                        setStatus(itemStatus, `Only ${item.availableQuantity} ${item.itemName} ${item.availableQuantity === 1 ? "is" : "are"} available right now.`, "error");
                        focusItemScan();
                        return;
                    }

                    item.quantity += 1;
                    setStatus(itemStatus, `${item.itemName} quantity increased.`, "info");
                } else if (action === "decrement") {
                    item.quantity -= 1;

                    if (item.quantity <= 0) {
                        state.cart.delete(upc);
                        setStatus(itemStatus, `${item.itemName} removed from checkout.`, "info");
                    } else {
                        setStatus(itemStatus, `${item.itemName} quantity decreased.`, "info");
                    }
                }

                renderCart();
                focusItemScan();
            });

            renderCart();
            focusLookup();
        });
    </script>
}
