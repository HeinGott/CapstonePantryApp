@model Pantreats.Models.DonorDashboardViewModel

@{
    ViewData["Title"] = "Donor Dashboard";
    Layout = "_Layout";
}

<div class="donor-page">

    <div class="donor-page-header">
        <div>
            <h1 class="donor-page-title">Donor Dashboard</h1>
            <p class="donor-page-subtitle">Welcome, @Model.DonorName</p>
        </div>

        <a asp-controller="Donor"
           asp-action="CreateDonation"
           class="btn donor-primary-btn">
            Make a Donation
        </a>
    </div>

    <div class="row mt-4">
        <div class="col-md-4 mb-3">
            <div class="donor-card donor-stat-card">
                <h5>Total Donations</h5>
                <h2>@Model.TotalDonations</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="donor-card donor-stat-card">
                <h5>Total Items Donated</h5>
                <h2>@Model.TotalItemsDonated</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="donor-card donor-stat-card">
                <h5>Last Donation</h5>
                <h2>@Model.LastDonationDate?.ToShortDateString()</h2>
            </div>
        </div>
    </div>

    <h3 class="donor-page-title mt-5">Donation History</h3>

    <div class="donor-card mt-3">
        <div class="table-responsive">
            <table class="table donor-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Item</th>
                        <th>Quantity</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var donation in Model.Donations)
                    {
                        foreach (var item in donation.DonationItems)
                        {
                            <tr class="donor-row">
                                <td>@donation.DonationDate.ToShortDateString()</td>
                                <td>@item.ItemName</td>
                                <td>@item.Quantity</td>
                                <td>
                                    <span class="donor-status pending">
                                        @donation.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>