@model Pantreats.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["FullWidth"] = true;
    var adminName = User.Identity?.Name ?? "Admin";
    var displayName = adminName.Contains('@') ? adminName.Split('@')[0] : adminName;
}

<div class="admin-dashboard">
    <section class="admin-hero">
        <div class="admin-hero-copy">
            <span class="admin-eyebrow">Admin Dashboard</span>
            <h1 class="admin-page-title mb-2">Hello, @displayName</h1>
            <p class="admin-page-subtitle mb-0">
                Keep orders moving, review applications, and stay on top of incoming donations from one clean workspace.
            </p>
        </div>

        <div class="admin-date-card">
            <span>Today</span>
            <strong>@DateTime.Today.ToString("dddd, MMMM d")</strong>
        </div>
    </section>

    <section class="admin-work-section">
        <div class="admin-section-heading">
            <div>
                <h2>Quick View</h2>
            </div>
            <p>Check below to see if anything needs attention.</p>
        </div>

        <div class="admin-work-grid">
            <a asp-controller="OrderFulfilments" asp-action="Index" class="admin-queue-card admin-queue-orders">
                <i class="bi bi-bag-check admin-queue-icon"></i>
                <span class="admin-queue-content">
                    <span class="admin-queue-label">New orders</span>
                    <small>Still need admin action</small>
                </span>
                <strong class="admin-queue-count">@Model.NewOrders</strong>
                <i class="bi bi-arrow-right admin-queue-arrow"></i>
            </a>

            <a asp-controller="Student" asp-action="Index" class="admin-queue-card admin-queue-applications">
                <i class="bi bi-file-earmark-person admin-queue-icon"></i>
                <span class="admin-queue-content">
                    <span class="admin-queue-label">Pending applications</span>
                    <small>Waiting for an admin decision</small>
                </span>
                <strong class="admin-queue-count">@Model.PendingApplications</strong>
                <i class="bi bi-arrow-right admin-queue-arrow"></i>
            </a>

            <a asp-controller="Volunteer" asp-action="Index" class="admin-queue-card admin-queue-applications">
                <i class="bi bi-people admin-queue-icon"></i>
                <span class="admin-queue-content">
                    <span class="admin-queue-label">Pending volunteers</span>
                    <small>Waiting for an admin decision</small>
                </span>
                <strong class="admin-queue-count">@Model.PendingVolunteerApplications</strong>
                <i class="bi bi-arrow-right admin-queue-arrow"></i>
            </a>

            <a asp-controller="Admin" asp-action="Donations" class="admin-queue-card admin-queue-donations">
                <i class="bi bi-gift admin-queue-icon"></i>
                <span class="admin-queue-content">
                    <span class="admin-queue-label">New donations</span>
                    <small>Waiting for review</small>
                </span>
                <strong class="admin-queue-count">@Model.NewDonations</strong>
                <i class="bi bi-arrow-right admin-queue-arrow"></i>
            </a>
        </div>
    </section>

    <section class="admin-data-grid">
        <div class="admin-panel admin-panel-orders">
            <div class="admin-panel-header">
                <div>
                    <span class="admin-panel-kicker">Orders</span>
                    <h2 class="admin-panel-title mb-0">Recent student orders</h2>
                </div>
                <a asp-controller="OrderFulfilments" asp-action="Index" class="admin-text-link">
                    View all <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="admin-list">
                @if (!Model.RecentOrders.Any())
                {
                    <div class="admin-empty-state">
                        <i class="bi bi-bag"></i>
                        <span>No student orders currently need admin action.</span>
                    </div>
                }
                else
                {
                    @foreach (var order in Model.RecentOrders)
                    {
                        var statusClass = order.Status.Equals(Pantreats.Models.OrderFulfilment.StatusCompleted, StringComparison.OrdinalIgnoreCase)
                            ? "is-complete"
                            : "is-pending";

                        <a asp-controller="Order" asp-action="Details" asp-route-id="@order.OrderId"
                           class="admin-list-row">
                            <span class="admin-list-main">
                                <strong>Order #@order.OrderId</strong>
                                <small>@order.StudentEmail</small>
                            </span>
                            <span class="admin-list-meta">
                                <span>@order.ItemCount items / @order.PointsUsed pts</span>
                                <small>@order.SubmittedAt.ToString("MMM d, h:mm tt")</small>
                            </span>
                            <span class="admin-status @statusClass">@order.Status</span>
                        </a>
                    }
                }
            </div>
        </div>

        <div class="admin-panel admin-panel-applications">
            <div class="admin-panel-header">
                <div>
                    <span class="admin-panel-kicker">Applications</span>
                    <h2 class="admin-panel-title mb-0">Pending applications</h2>
                </div>
                <a asp-controller="Student" asp-action="Index" class="admin-text-link">
                    View all <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="admin-list">
                @if (!Model.RecentApplications.Any())
                {
                    <div class="admin-empty-state">
                        <i class="bi bi-check2-circle"></i>
                        <span>There are no applications waiting for review.</span>
                    </div>
                }
                else
                {
                    @foreach (var application in Model.RecentApplications)
                    {
                        <a asp-controller="Student" asp-action="Details" asp-route-id="@application.ApplicationId"
                           class="admin-list-row admin-list-row-compact">
                            <span class="admin-list-main">
                                <strong>@application.StudentName</strong>
                                <small>Student ID @application.StudentId</small>
                            </span>
                            <span class="admin-list-meta">
                                <span>Review needed</span>
                                <small>@application.SubmittedAt.ToLocalTime().ToString("MMM d")</small>
                            </span>
                        </a>
                    }
                }
            </div>
        </div>

        <div class="admin-panel admin-panel-donations">
            <div class="admin-panel-header">
                <div>
                    <span class="admin-panel-kicker">Donations</span>
                    <h2 class="admin-panel-title mb-0">Recent donations</h2>
                </div>
                <a asp-controller="Admin" asp-action="Donations" class="admin-text-link">
                    View all <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="admin-list">
                @if (!Model.RecentDonations.Any())
                {
                    <div class="admin-empty-state">
                        <i class="bi bi-gift"></i>
                        <span>No donations have been recorded yet.</span>
                    </div>
                }
                else
                {
                    @foreach (var donation in Model.RecentDonations)
                    {
                        var donationStatusClass = donation.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase)
                            ? "is-complete"
                            : donation.Status.Equals("Denied", StringComparison.OrdinalIgnoreCase)
                                ? "is-denied"
                                : "is-pending";

                        <a asp-controller="Admin" asp-action="Donations" class="admin-list-row">
                            <span class="admin-list-main">
                                <strong>@donation.DonorName</strong>
                                <small>@donation.ItemCount item types / @donation.TotalUnits total units</small>
                            </span>
                            <span class="admin-list-meta">
                                <small>@donation.SubmittedAt.ToString("MMM d, yyyy")</small>
                            </span>
                            <span class="admin-status @donationStatusClass">@donation.Status</span>
                        </a>
                    }
                }
            </div>
        </div>
    </section>
</div>
