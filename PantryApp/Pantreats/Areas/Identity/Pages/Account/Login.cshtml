@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container pt-1 py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <div class="student-card p-4 p-md-5">
                
                <div class="text-center mb-4">
                    <img src="/images/SCC-Logo.png"
                         alt="SCC Logo"
                         style="max-width:100%; width:380px; height:auto;" />
                </div>

                <form id="account" method="post">

                    <h2 class="text-center mb-2">Welcome Back</h2>

                    <p class="text-center student-page-subtitle mb-4">
                        Sign in to continue to your SCC account.
                    </p>

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"
                         role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email"
                               class="form-control"
                               placeholder="example@gmail.com"
                               autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Password</label>

                        <div class="input-group">
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   id="passwordInput"
                                   placeholder="Enter your password"
                                   autocomplete="current-password" />

                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    id="togglePasswordButton">
                                Show
                            </button>
                        </div>

                        <span asp-validation-for="Input.Password"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input class="form-check-input"
                               asp-for="Input.RememberMe" />

                        <label class="form-check-label"
                               asp-for="Input.RememberMe">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <div class="d-grid">
                        <button id="login-submit"
                                type="submit"
                                class="btn btn-lg btn-primary">
                            Log in
                        </button>
                    </div>

                </form>

                @if (Model.ExternalLogins != null && Model.ExternalLogins.Count > 0)
                {
                    <div class="text-center mt-4">

                        <form asp-page="./ExternalLogin"
                              asp-route-returnUrl="@Model.ReturnUrl"
                              method="post">

                            @foreach (var provider in Model.ExternalLogins)
                            {
                                if (provider.Name == "Microsoft")
                                {
                                    <button type="submit"
                                            name="provider"
                                            value="@provider.Name"
                                            class="btn d-flex align-items-center gap-2 mx-auto"
                                            title="Log in with Microsoft">

                                        <img src="~/images/microsoftLoginIcon.svg"
                                             asp-append-version="true"
                                             alt="Microsoft"
                                             style="height:50px; width:auto;" />

                                        <span class="fs-5">Continue with Microsoft</span>
                                    </button>
                                }
                            }

                        </form>

                    </div>
                }

                <div class="text-center mt-4">
                    <p class="mb-2">
                        <a asp-page="./ForgotPassword">
                            Forgot your password?
                        </a>
                    </p>

                    <p class="mb-2">
                        <a asp-page="./Register"
                           asp-route-returnUrl="@Model.ReturnUrl">
                            Create an account
                        </a>
                    </p>

                    <p class="mb-2">
                        <a asp-page="./ResendEmailConfirmation">
                            Resend email confirmation
                        </a>
                    </p>

                    <p class="mb-2">
                        <a asp-controller="Donor" asp-action="Register">
                            Register as a new donor
                        </a>
                    </p>
                </div>

            </div>
        </div>
    </div>
   

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    
    <script>
        const passwordInput = document.getElementById("passwordInput");
        const togglePasswordButton = document.getElementById("togglePasswordButton");

        togglePasswordButton.addEventListener("click", function () {
            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                togglePasswordButton.textContent = "Hide";
            }
            else {
                passwordInput.type = "password";
                togglePasswordButton.textContent = "Show";
            }
        });
    </script>
    

}
