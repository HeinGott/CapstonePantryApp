@*
    this is the login page for the vendor, which is currently not implemented.
    made by eric and jorge
*@
@{
    ViewData["Title"] = "Donor Login";
}

<div class="d-flex justify-content-center mt-4">
    <div style="width: 420px;">

        <h2 class="text-center mb-3">Donor Login</h2>
        <hr />

        <form>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" placeholder="example@gmail.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" placeholder="Enter your password" />
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" />
                <label class="form-check-label">Remember me?</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Log in
            </button>

            <div class="text-center mt-4">
                <a asp-controller="Donor" asp-action="Register">Register as a donor</a>
            </div>
        </form>

    </div>
</div>

