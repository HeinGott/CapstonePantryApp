@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="student-card p-4 p-md-5 text-center">
                <h1 class="mb-3">@ViewData["Title"]</h1>
                <p class="student-page-subtitle mb-3">
                    We created your @(Model.AccountType == "student" ? "student" : "donor") account for <strong>@Model.Email</strong>.
                </p>
                <p class="mb-4">
                    Please confirm your email before continuing.
                </p>

                @if (Model.DisplayConfirmAccountLink)
                {
                    <div class="alert alert-light border text-start mb-4" role="alert">
                        <p class="mb-2">Local email sender is not configured yet, so the confirmation link is shown here for now.</p>
                        <a id="confirm-link" href="@Model.EmailConfirmationUrl">Click here to confirm your account</a>
                    </div>
                }

                <div class="d-grid gap-3">
                    <a asp-page="./Login" class="btn btn-primary btn-lg">Back To Login</a>
                    @if (!string.IsNullOrWhiteSpace(Model.ContinueUrl))
                    {
                        <a href="@Model.ContinueUrl" class="btn btn-outline-secondary btn-lg">@Model.ContinueLabel</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
