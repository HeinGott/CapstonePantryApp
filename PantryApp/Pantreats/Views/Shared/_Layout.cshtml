@inject Pantreats.Data.ApplicationDbContext DbContext
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChaserPantryApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChaserPantryApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var hideNavbar = ViewData["HideNavbar"] as bool? ?? false;
        var hideFooter = ViewData["HideFooter"] as bool? ?? false;
        var fullWidth = ViewData["FullWidth"] as bool? ?? false;
        var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        var hasApprovedStudentAccess = false;

        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            hasApprovedStudentAccess = DbContext.UserApplications
                .Where(application => application.UserId == currentUserId)
                .OrderByDescending(application => application.RegistrationDate)
                .ThenByDescending(application => application.ApplicationId)
                .Select(application => application.ApplicationStatus == Pantreats.Models.ApplicationStatuses.Approved)
                .FirstOrDefault();
        }
    }

    <div class="pantreats-page-shell">
        @if (!hideNavbar)
        {
            <header>
                <nav class="navbar navbar-expand-sm pantreats-navbar">
                    <div class="container-fluid">
                        <a class="navbar-brand pantreats-brand" asp-area="" asp-controller="Home" asp-action="Index">
                            PanTreats
                        </a>

                        <button class="navbar-toggler pantreats-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Home" asp-action="Index">Home</a>
                                </li>

                                <!-- ADMIN LAYOUT BAR -->
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Kiosk" asp-action="Index">Kiosk</a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Inventory" asp-action="Index">
                                            Inventory
                                        </a>
                                    </li>
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Orders
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="OrderFulfilments" asp-action="Index">Order Fulfilment</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Order" asp-action="History">Order History</a>
                                            </li>
                                        </ul>
                                    </li>                                  
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Admin" asp-action="Users">
                                            Users
                                        </a>
                                    </li>

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Applications
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Student" asp-action="Index">Student Applications</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Volunteer" asp-action="Index">Volunteer Applications</a>
                                            </li>
                                        </ul>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Volunteer" asp-action="ScheduleRequests">Schedule</a>
                                    </li>
                                                                       

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Donors
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Donor" asp-action="Index">View Donors</a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Admin" asp-action="Donations">Donation Approval</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item"
                                                   asp-controller="Admin"
                                                   asp-action="ReceivingDonations">
                                                    Receiving Donations
                                                </a>
                                            </li>
                                        </ul>
                                    </li>

                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Reports
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Reports" asp-action="Inventory">Inventory Reports</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Reports" asp-action="Students">Student Reports</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Reports" asp-action="Usage">Pantry Usage</a>
                                            </li>
                                        </ul>
                                    </li>   
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link"
                                           asp-controller="Recipe"
                                           asp-action="Index">
                                            Recipes
                                        </a>
                                    </li>
                                }

                                <!-- STUDENT LAYOUT BAR -->
                                @if (User.IsInRole("Students"))
                                {                                    
                                    @if (hasApprovedStudentAccess)
                                    {
                                        <li class="nav-item">
                                            <a class="nav-link pantreats-nav-link" asp-controller="Shop" asp-action="Index">Shop</a>
                                        </li> 
                                        
                                        <li class="nav-item">
                                            <a class="nav-link pantreats-nav-link" asp-controller="Order" asp-action="History">Orders</a>
                                        </li>

                                        <li class="nav-item">
                                            <a class="nav-link pantreats-nav-link" asp-controller="Recipe" asp-action="Index">Recipes</a>
                                        </li>

                                        <li class=" nav-item">
                                            <a class="nav-link pantreats-nav-link" asp-controller="Volunteer" asp-action="ApplyVolunteer">Volunteer</a>
                                        </li>                                        
                                    }

                                    <li class=" nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Student" asp-action="Status">Apply</a>
                                    </li>
                                }

                                @if (User.IsInRole("Kiosk"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Kiosk" asp-action="Index">Kiosk</a>
                                    </li>
                                }

                                @if (User.Identity?.IsAuthenticated == true &&
                                    !User.IsInRole("Admin") &&
                                    !User.IsInRole("Students") &&
                                    !User.IsInRole("Volunteers") &&
                                    !User.IsInRole("Donors") &&
                                    !User.IsInRole("Kiosk"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Student" asp-action="Status">Application</a>
                                    </li>
                                }

                                <!-- VOLUNTEER LAYOUT BAR -->
                                @if (User.IsInRole("Volunteers"))
                                {                                    
                                    <li class=" nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Volunteer" asp-action="Dashboard">Dashboard</a>
                                    </li>                                    
                                                                            
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle pantreats-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Orders
                                        </a>
                                        <ul class="dropdown-menu pantreats-dropdown-menu">
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="OrderFulfilments" asp-action="Index">Order Fulfilment</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item pantreats-dropdown-item" asp-controller="Order" asp-action="History">Order History</a>
                                            </li>
                                        </ul>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Volunteer" asp-action="Schedule">Schedule</a>
                                    </li>                                   

                                    @if (hasApprovedStudentAccess)
                                    {
                                        <li class="nav-item">
                                            <a class="nav-link pantreats-nav-link" asp-controller="Shop" asp-action="Index">Shop</a>
                                        </li>

                                        <li class="nav-item">
                                            <a class="nav-link pantreats-nav-link"
                                               asp-controller="Recipe"
                                               asp-action="Index">
                                                Recipes
                                            </a>
                                        </li>
                                    }
                                    <li class=" nav-item">
                                        <a class="nav-link pantreats-nav-link" asp-controller="Student" asp-action="Status">Apply</a>
                                    </li>
                                        
                                }

                                <!-- DONOR LAYOUT BAR -->
                                @if (User.IsInRole("Donors"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link pantreats-nav-link"
                                           asp-controller="Donor"
                                           asp-action="Dashboard">
                                            Dashboard
                                        </a>
                                    </li>
                                }
                                <!-- DEFAULT LAYOUT BAR -->
                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Home" asp-action="About">About</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link pantreats-nav-link" asp-controller="Support" asp-action="Index">Support</a>
                                </li>
                            </ul>

                            <partial name="_LoginPartial" />
                        </div>
                    </div>
                </nav>
            </header>
        }

        <div class="pantreats-page-content">
            @if (fullWidth)
            {
                <main role="main" class="pantreats-main-full">
                    @RenderBody()
                </main>
            }
            else
            {
                <main role="main" class="pantreats-main-standard">
                    <div class="container pt-4 pb-3">
                        @RenderBody()
                    </div>
                </main>
            }
        </div>

        @if (!hideFooter)
        {
            <footer class="pantreats-footer">
                <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span>&copy; 2026 - PanTreats</span>
                    <a asp-controller="Home" asp-action="Privacy" class="pantreats-footer-link">Privacy</a>
                </div>
            </footer>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
