@model Pantreats.Models.StudentAdminIndexViewModel

@{
    ViewData["Title"] = "Students";
}

<div class="student-page py-4">
    <div class="student-page-header mb-4">
        <div>
            <h1 class="student-page-title mb-1">Students</h1>
            <p class="student-page-subtitle mb-0">
                Review pending applications and manage approved student pantry users.
            </p>
        </div>
    </div>

    <div class="student-card mb-4">
        <div class="student-history-header mb-3">
            <div>
                <h2 class="student-section-title mb-1">Pending Applicants</h2>
                <p class="student-page-subtitle mb-0">
                    These applications still need an admin decision.
                </p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table student-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Student ID</th>
                        <th>Email</th>
                        <th>Submitted</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.PendingApplications.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-muted">No pending applications right now.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var application in Model.PendingApplications)
                        {
                            <tr class="student-row"
                                role="button"
                                tabindex="0"
                                onclick="goToStudentDetails(@application.ApplicationId)"
                                onkeydown="openStudentDetailsFromKey(event, @application.ApplicationId)">
                                <td>@application.FullName</td>
                                <td>@application.StudentId</td>
                                <td>@application.Email</td>
                                <td>@application.SubmittedAt.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="student-card">
        <div class="student-history-header mb-3">
            <div>
                <h2 class="student-section-title mb-1">Approved Students</h2>
                <p class="student-page-subtitle mb-0">
                    Active students with pantry access and order history.
                </p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table student-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Student ID</th>
                        <th>Email</th>
                        <th>Approved Record</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.ApprovedStudents.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-muted">No approved students yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var student in Model.ApprovedStudents)
                        {
                            <tr class="student-row"
                                role="button"
                                tabindex="0"
                                onclick="goToStudentDetails(@student.ApplicationId)"
                                onkeydown="openStudentDetailsFromKey(event, @student.ApplicationId)">
                                <td>@student.FullName</td>
                                <td>@student.StudentId</td>
                                <td>@student.Email</td>
                                <td>@student.SubmittedAt.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function goToStudentDetails(id) {
            window.location.href = '/Student/Details/' + id;
        }

        function openStudentDetailsFromKey(event, id) {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                goToStudentDetails(id);
            }
        }
    </script>
}
