@model Pantreats.Models.StudentDetailsViewModel

@{
    ViewData["Title"] = "Student Details";

    string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToString("MM/dd/yyyy") : "Not provided";
    string FormatDateTime(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("MM/dd/yyyy h:mm tt") : "Not reviewed yet";
    string FormatLastReset(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("MM/dd/yyyy h:mm tt") : "Not reset yet";
    string FormatBool(bool value) => value ? "Yes" : "No";
    string FormatNullableBool(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Not provided";
    string FormatNullablePoints(int? value) => value.HasValue ? $"{value.Value} points" : "Not assigned";
}

<div class="student-details-page py-4">
    @if (TempData["StatusMessage"] is string statusMessage)
    {
        var statusType = TempData["StatusType"] as string;
        var alertClass = string.Equals(statusType, "error", StringComparison.OrdinalIgnoreCase)
            ? "alert-danger"
            : "alert-success";

        <div class="alert @alertClass" role="alert">
            @statusMessage
        </div>
    }

    <div class="mb-3 d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <a asp-action="Index" class="btn student-back-btn">&larr; Back to Students</a>

        <form asp-action="DeleteApplication"
              asp-route-id="@Model.ApplicationId"
              method="post"
              onsubmit="return confirm('Are you sure you want to delete this student application? This cannot be undone.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                Delete Application
            </button>
        </form>
    </div>

    <section class="student-review-shell mb-4">
        <div class="student-review-hero">
            <div>
                <p class="student-review-eyebrow mb-2">Application Review</p>
                <h1 class="student-details-title mb-1">@Model.FullName</h1>
                <p class="student-details-subtitle mb-1">Student ID: @Model.StudentId</p>
            </div>

            <div class="student-review-status-wrap">
                <span class="student-review-badge student-review-badge-@Model.ApplicationStatus.ToLowerInvariant()">
                    @Model.ApplicationStatus
                </span>
            </div>
        </div>

        <div class="student-review-summary">
            <div class="student-review-summary-item">
                <span>Campus</span>
                <strong>@Model.Campus</strong>
            </div>
            <div class="student-review-summary-item">
                <span>Student Status</span>
                <strong>@Model.StudentStatus</strong>
            </div>
            <div class="student-review-summary-item">
                <span>Submitted</span>
                <strong>@FormatDateTime(Model.SubmittedAt)</strong>
            </div>
            <div class="student-review-summary-item">
                <span>Reviewed</span>
                <strong>@FormatDateTime(Model.ReviewedAt)</strong>
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Point Balance</h2>
                <p class="student-page-subtitle mb-0">Monthly pantry allowance and currently available balance.</p>
            </div>
        </div>

        <div class="student-fact-list">
            <div class="student-fact-row">
                <span>Monthly recurring balance</span>
                <strong>@FormatNullablePoints(Model.MonthlyPointBalance)</strong>
            </div>
            <div class="student-fact-row">
                <span>Current balance</span>
                <strong>@FormatNullablePoints(Model.CurrentPointBalance)</strong>
            </div>
            <div class="student-fact-row">
                <span>Last monthly reset</span>
                <strong>@FormatLastReset(Model.LastPointResetAt)</strong>
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Identity</h2>
                <p class="student-page-subtitle mb-0">Core student information for verification.</p>
            </div>
        </div>

        <div class="student-fact-list">
            <div class="student-fact-row">
                <span>Full legal name</span>
                <strong>@Model.DisplayLegalName</strong>
            </div>
            <div class="student-fact-row">
                <span>Email</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Email) ? "Not available" : Model.Email)</strong>
            </div>
            <div class="student-fact-row">
                <span>Student ID</span>
                <strong>@Model.StudentId</strong>
            </div>
            <div class="student-fact-row">
                <span>Phone number</span>
                <strong>@Model.DisplayPhoneNumber</strong>
            </div>
            <div class="student-fact-row">
                <span>Date of birth</span>
                <strong>@FormatDate(Model.DateOfBirth)</strong>
            </div>
            <div class="student-fact-row">
                <span>Gender</span>
                <strong>@Model.DisplayGender</strong>
            </div>
            <div class="student-fact-row">
                <span>Application record</span>
                <strong>#@Model.ApplicationId</strong>
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Need Snapshot</h2>
                <p class="student-page-subtitle mb-0">Quick context for household and support needs.</p>
            </div>
        </div>

        <div class="student-fact-list student-fact-list-compact">
            <div class="student-fact-row">
                <span>Household size</span>
                <strong>@Model.HouseholdTotal people</strong>
            </div>
            <div class="student-fact-stack">
                <span>Household breakdown</span>
                <div class="student-support-pills student-support-pills-tight">
                    <span class="student-support-pill">@Model.HouseholdBabiesToddlers babies</span>
                    <span class="student-support-pill">@Model.HouseholdChildren children</span>
                    <span class="student-support-pill">@Model.HouseholdTeens teens</span>
                    <span class="student-support-pill">@Model.HouseholdAdults adults</span>
                </div>
            </div>
            <div class="student-fact-row">
                <span>Employment</span>
                <strong>@Model.EmploymentStatus</strong>
            </div>
            <div class="student-fact-row student-fact-subrow">
                <span>Working household members</span>
                <strong>@Model.EmployedHouseMembers</strong>
            </div>
            <div class="student-fact-row">
                <span>Transportation access</span>
                <strong>@FormatNullableBool(Model.HasTransportation)</strong>
            </div>
            <div class="student-fact-stack">
                <span>Current benefits</span>
                <div class="student-support-pills student-support-pills-tight">
                    <span class="student-support-pill @(Model.HasSnap ? "active" : "")">SNAP: @FormatBool(Model.HasSnap)</span>
                    <span class="student-support-pill @(Model.HasWic ? "active" : "")">WIC: @FormatBool(Model.HasWic)</span>
                    <span class="student-support-pill @(Model.HasTanf ? "active" : "")">TANF: @FormatBool(Model.HasTanf)</span>
                </div>
            </div>
        </div>
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Support Interest</h2>
                <p class="student-page-subtitle mb-0">Programs the student wants help connecting to.</p>
            </div>
        </div>

        <div class="student-support-pills">
            <span class="student-support-pill @(Model.InterestedInSnap ? "active" : "")">SNAP Help: @FormatBool(Model.InterestedInSnap)</span>
            <span class="student-support-pill @(Model.InterestedInWic ? "active" : "")">WIC Help: @FormatBool(Model.InterestedInWic)</span>
            <span class="student-support-pill @(Model.InterestedInTanf ? "active" : "")">TANF Help: @FormatBool(Model.InterestedInTanf)</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ReviewNotes))
        {
            <div class="student-review-note mt-4">
                <span>Latest Review Notes</span>
                <p class="mb-0">@Model.ReviewNotes</p>
            </div>
        }
    </section>

    <section class="student-review-panel mb-4">
        <div class="student-review-panel-header">
            <div>
                <h2 class="student-section-title mb-1">Decision</h2>
                <p class="student-page-subtitle mb-0">Approve or reject after reviewing the application details.</p>
            </div>
        </div>

        @if (Model.ApplicationStatus == Pantreats.Models.ApplicationStatuses.Pending)
        {
            <div class="student-decision-grid">
                <form asp-action="Approve" asp-route-id="@Model.ApplicationId" method="post" class="student-decision-form student-decision-form-approve">
                    @Html.AntiForgeryToken()
                    <label class="form-label">Monthly point balance</label>
                    <input name="monthlyPointBalance"
                           type="number"
                           min="0"
                           class="form-control"
                           value="@(Model.MonthlyPointBalance ?? 0)"
                           required />
                    <label class="form-label">Approval notes</label>
                    <textarea name="reviewNotes" class="form-control" rows="4" placeholder="Optional note for the application record"></textarea>
                    <button type="submit" class="btn btn-success mt-3">Approve Student</button>
                </form>

                <form asp-action="Reject" asp-route-id="@Model.ApplicationId" method="post" class="student-decision-form student-decision-form-reject">
                    @Html.AntiForgeryToken()
                    <label class="form-label">Rejection notes</label>
                    <textarea name="reviewNotes" class="form-control" rows="4" placeholder="Tell the student what needs to be fixed"></textarea>
                    <button type="submit" class="btn btn-outline-danger mt-3">Reject Application</button>
                </form>
            </div>
        }
        else
        {
            @if (Model.ApplicationStatus == Pantreats.Models.ApplicationStatuses.Approved)
            {
                <form asp-action="UpdateApprovedStudent" asp-route-id="@Model.ApplicationId" method="post" class="student-decision-form student-decision-form-approve">
                    @Html.AntiForgeryToken()
                    <div class="student-fact-list mb-3">
                        <div class="student-fact-row">
                            <span>Current status</span>
                            <strong>@Model.ApplicationStatus</strong>
                        </div>
                        <div class="student-fact-row">
                            <span>Reviewed on</span>
                            <strong>@FormatDateTime(Model.ReviewedAt)</strong>
                        </div>
                    </div>

                    <label class="form-label">Monthly point balance</label>
                    <input name="monthlyPointBalance"
                           type="number"
                           min="0"
                           class="form-control"
                           value="@(Model.MonthlyPointBalance ?? 0)"
                           required />

                    <label class="form-label mt-3">Current point balance</label>
                    <input name="currentPointBalance"
                           type="number"
                           min="0"
                           class="form-control"
                           value="@(Model.CurrentPointBalance ?? Model.MonthlyPointBalance ?? 0)"
                           required />

                    <label class="form-label mt-3">Review notes</label>
                    <textarea name="reviewNotes" class="form-control" rows="4" placeholder="Optional note for the application record">@Model.ReviewNotes</textarea>

                    <button type="submit" class="btn btn-primary mt-3">Save Student Access</button>
                </form>
            }
            else
            {
                <div class="student-fact-list">
                    <div class="student-fact-row">
                        <span>Current status</span>
                        <strong>@Model.ApplicationStatus</strong>
                    </div>
                    <div class="student-fact-row">
                        <span>Reviewed on</span>
                        <strong>@FormatDateTime(Model.ReviewedAt)</strong>
                    </div>
                </div>
            }
        }
    </section>

    @if (Model.ShowOrderHistory)
    {
        <section class="student-card">
            <div class="student-history-header mb-3">
                <div>
                    <h2 class="student-section-title mb-1">Order History</h2>
                    <p class="student-page-subtitle mb-0">
                        Available after approval so admins can review pantry usage over time.
                    </p>
                </div>
            </div>

            <div class="student-order-meta mb-3">
                <span>Total Orders</span>
                <strong>@Model.TotalOrders</strong>
            </div>

            <div class="table-responsive">
                <table class="table student-table align-middle mb-0" id="historyTable">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Items</th>
                            <th>Points Used</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.OrderHistory.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-muted">This student has not placed any orders yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.OrderHistory)
                            {
                                <tr class="student-history-row">
                                    <td>
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId">#@item.OrderId</a>
                                    </td>
                                    <td>@item.OrderDate.ToString("MM/dd/yyyy")</td>
                                    <td>@item.Status</td>
                                    <td>@item.ItemCount</td>
                                    <td>@item.PointsUsed</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
