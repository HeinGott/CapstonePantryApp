@model UserApplicationViewModel

@{
    ViewData["Title"] = "Apply";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
}

<div class="pantreats-white-section">
    <div class="container">

        <div class="student-card mx-auto" style="max-width: 1100px;">

            <!-- HEADER -->
            <div class="mb-4 text-center">
                <img src="/Images/pantreatsLogo.png" class="mb-3" style="max-width: 220px;">
                <h1 class="section-title">
                    User Application
                </h1>
                <p class="section-text">Please provide the following information</p>
            </div>

            <!-- VALIDATION SUMMARY -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-controller="Student" asp-action="UserApplicationForm" method="post">

                <!-- BASIC INFO -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Basic Information</h5>

                <div class="row g-3 mb-4">

                    <div class="col-md-4">
                        <label class="form-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Middle Name</label>
                        <input asp-for="MiddleName" class="form-control" />
                        <span asp-validation-for="MiddleName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Student ID</label>
                        <input asp-for="StudentId" class="form-control" type="number" required/>
                        <span asp-validation-for="StudentId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 pantreats-date-field">
                        <label class="form-label">DOB</label>
                        <input asp-for="DOB"
                               type="text"
                               class="form-control pantreats-date-input"
                               id="studentDobInput"
                               min="1960-01-01" />
                        <span asp-validation-for="DOB" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Phone</label>
                        <input asp-for="PhoneNum" class="form-control" />
                        <span asp-validation-for="PhoneNum" class="text-danger"></span>
                    </div>
                </div>

                <!-- STUDENT INFO -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Student Info</h5>

                <div class="row g-3 mb-4">

                    <div class="col-md-6">
                        <label class="form-label">Student Status</label>
                        <select asp-for="StudentStatus" class="form-select">
                            <option value="">-- Select Status --</option>
                            <option value="Single">Single</option>
                            <option value="Married">Married</option>
                            <option value="Widowed">Widowed</option>
                            <option value="Divorced">Divorced</option>
                        </select>
                        <span asp-validation-for="StudentStatus" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">-- Select Gender --</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <!-- ETHNICITY -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Ethnicity</h5>

                <div class="mb-4">
                    <select asp-for="Ethnicity" class="form-select">
                        <option value="">-- Select Ethnicity --</option>
                        <option value="African American">African American</option>
                        <option value="Asian">Asian</option>
                        <option value="Caucasian">Caucasian</option>
                        <option value="Latino">Latino</option>
                        <option value="Middle Eastern">Middle Eastern</option>
                        <option value="Native American">Native American</option>
                        <option value="Pacific Islander">Pacific Islander</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Ethnicity" class="text-danger"></span>
                </div>

                <!-- CAMPUS -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Campus</h5>

                <div class="mb-4">
                    <select asp-for="Campus" class="form-select">
                        <option value="">-- Select Campus --</option>
                        <option value="Spartanburg">Spartanburg</option>
                        <option value="Downtown">Downtown</option>
                        <option value="Cherokee">Cherokee</option>
                        <option value="Tyger River">Tyger River</option>
                        <option value="Union">Union</option>
                    </select>
                    <span asp-validation-for="Campus" class="text-danger"></span>
                </div>

                <!-- HOUSEHOLD -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Household Members Info</h5>

                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Age 0-4</label>
                        <input asp-for="HouseholdBabiesToddlers" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Age 5-12</label>
                        <input asp-for="HouseholdBabiesChildren" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Age 13-17</label>
                        <input asp-for="HouseholdTeens" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Age 18+</label>
                        <input asp-for="HouseholdAdults" class="form-control" />
                    </div>
                </div>

                <!-- EMPLOYMENT -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Employment</h5>

                <div class="row g-3 mb-4">

                    <div class="col-md-6">
                        <label class="form-label">Employment Status</label>
                        <select asp-for="EmploymentStatus" class="form-select">
                            <option value="">-- Select Employment Status --</option>
                            <option value="Full-Time">Full-Time</option>
                            <option value="Part-Time">Part-Time</option>
                            <option value="Unemployed">Unemployed</option>
                            <option value="Student Only">Student Only</option>
                        </select>
                        <span asp-validation-for="EmploymentStatus" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Employed Household Members</label>
                        <input asp-for="EmployedHouseMembers" class="form-control" />
                    </div>
                </div>

                <!-- TRANSPORTATION -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Transportation</h5>

                <div class="form-check mb-4">
                    <input asp-for="HasTransportation" class="form-check-input" />
                    <label class="form-check-label">Do you have reliable transportation?</label>
                </div>

                <!-- BENEFITS -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Current Benefits</h5>

                <div class="row mb-4">
                    <div class="col-md-3 form-check">
                        <input asp-for="HasSNAP" class="form-check-input" />
                        <label class="form-check-label">SNAP</label>
                    </div>

                    <div class="col-md-3 form-check">
                        <input asp-for="HasWIC" class="form-check-input" />
                        <label class="form-check-label">WIC</label>
                    </div>

                    <div class="col-md-3 form-check">
                        <input asp-for="HasTANF" class="form-check-input" />
                        <label class="form-check-label">TANF</label>
                    </div>
                </div>

                <!-- BENEFITS INTERESTED IN -->
                <h5 class="mb-3" style="color: var(--pantreats-blue);">Benefits Interested In</h5>

                <div class="row mb-4">

                    <div class="col-md-3 form-check">
                        <input asp-for="IsInterestedInSNAP" class="form-check-input" />
                        <label class="form-check-label">SNAP</label>
                    </div>

                    <div class="col-md-3 form-check">
                        <input asp-for="IsInterestedInWIC" class="form-check-input" />
                        <label class="form-check-label">WIC</label>
                    </div>

                    <div class="col-md-3 form-check">
                        <input asp-for="IsInterestedInTANF" class="form-check-input" />
                        <label class="form-check-label">TANF</label>
                    </div>

                </div>

                <!-- SUBMIT -->
                <div class="text-center mt-4">
                    <button type="submit" class="btn admin-tile-btn-featured px-5 py-2">
                        Submit
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const dobInput = document.getElementById("studentDobInput");

            if (!dobInput || typeof flatpickr === "undefined") {
                return;
            }

            function getYearPageStart(year) {
                return Math.max(1960, Math.floor((year - 1960) / 12) * 12 + 1960);
            }

            function wireYearPicker(instance) {
                const calendar = instance.calendarContainer;
                const yearInput = calendar.querySelector(".cur-year");

                if (!calendar || !yearInput || calendar.dataset.yearPickerReady === "true") {
                    return;
                }

                calendar.dataset.yearPickerReady = "true";
                yearInput.readOnly = true;
                yearInput.setAttribute("aria-label", "Choose year");
                yearInput.setAttribute("role", "button");

                let yearPageStart = getYearPageStart(instance.currentYear);
                const panel = document.createElement("div");
                panel.className = "pantreats-year-panel";
                panel.hidden = true;
                calendar.appendChild(panel);

                function renderYearPanel() {
                    const maxYear = new Date().getFullYear();
                    const maxPageStart = getYearPageStart(maxYear);
                    yearPageStart = Math.min(Math.max(1960, yearPageStart), maxPageStart);

                    const years = Array.from({ length: 12 }, (_, index) => yearPageStart + index);
                    const canGoBack = yearPageStart > 1960;
                    const canGoForward = yearPageStart < maxPageStart;

                    panel.innerHTML = `
                        <div class="pantreats-year-panel-header">
                            <button type="button" class="pantreats-year-panel-nav" data-year-direction="previous" ${canGoBack ? "" : "disabled"} aria-label="Previous years">&lsaquo;</button>
                            <span>${yearPageStart} - ${Math.min(yearPageStart + 11, maxYear)}</span>
                            <button type="button" class="pantreats-year-panel-nav" data-year-direction="next" ${canGoForward ? "" : "disabled"} aria-label="Next years">&rsaquo;</button>
                        </div>
                        <div class="pantreats-year-grid">
                            ${years.map(function (year) {
                                const isDisabled = year < 1960 || year > maxYear;
                                const isActive = year === instance.currentYear;
                                return `<button type="button" class="pantreats-year-option${isActive ? " is-active" : ""}" data-year="${year}" ${isDisabled ? "disabled" : ""}>${year}</button>`;
                            }).join("")}
                        </div>`;
                }

                function toggleYearPanel(forceOpen) {
                    const shouldOpen = typeof forceOpen === "boolean" ? forceOpen : panel.hidden;
                    yearPageStart = getYearPageStart(instance.currentYear);
                    renderYearPanel();
                    panel.hidden = !shouldOpen;
                }

                yearInput.addEventListener("click", function () {
                    toggleYearPanel();
                });

                yearInput.addEventListener("keydown", function (event) {
                    if (event.key === "Enter" || event.key === " ") {
                        event.preventDefault();
                        toggleYearPanel();
                    }
                });

                panel.addEventListener("pointerdown", function (event) {
                    event.stopPropagation();
                });

                panel.addEventListener("click", function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    const navButton = event.target.closest("[data-year-direction]");
                    const yearButton = event.target.closest("[data-year]");

                    if (navButton) {
                        yearPageStart += navButton.dataset.yearDirection === "next" ? 12 : -12;
                        renderYearPanel();
                        return;
                    }

                    if (yearButton) {
                        instance.jumpToDate(new Date(Number(yearButton.dataset.year), instance.currentMonth, 1));
                        toggleYearPanel(false);
                    }
                });

                document.addEventListener("click", function (event) {
                    if (!calendar.contains(event.target)) {
                        toggleYearPanel(false);
                    }
                });
            }

            flatpickr(dobInput, {
                altInput: true,
                altInputClass: "form-control pantreats-date-display",
                altFormat: "m/d/Y",
                allowInput: true,
                dateFormat: "Y-m-d",
                disableMobile: true,
                maxDate: "today",
                minDate: "1960-01-01",
                monthSelectorType: "static",
                position: "below left",
                static: true,
                onOpen: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length === 0) {
                        instance.jumpToDate("2000-01-01");
                    }
                    wireYearPicker(instance);
                },
                onReady: function (selectedDates, dateStr, instance) {
                    if (selectedDates.length === 0) {
                        instance.jumpToDate("2000-01-01");
                    }
                    wireYearPicker(instance);
                },
                onMonthChange: function (selectedDates, dateStr, instance) {
                    wireYearPicker(instance);
                },
                onYearChange: function (selectedDates, dateStr, instance) {
                    wireYearPicker(instance);
                }
            });
        });
    </script>
}
