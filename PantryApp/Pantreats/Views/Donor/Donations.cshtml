@model List<Pantreats.Models.Donation>

@*
    admin page to see all donations for a specific donor
*@
@{
    ViewData["Title"] = "Donor Donations";
}

<h1>Donor Donations</h1>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Donor</th>
            <th>Date</th>
            <th>Status</th>
            <th>Items</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var donation in Model)
        {
            <tr>
                <td>@donation.Donor?.Name</td>
                <td>@donation.DonationDate.ToShortDateString()</td>
                <td>@donation.Status</td>
                <td>
                    @foreach (var item in donation.DonationItems)
                    {
                        <div>@item.ItemName - Qty: @item.Quantity</div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>