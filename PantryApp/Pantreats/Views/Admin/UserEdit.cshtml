@model Pantreats.Models.UserEditViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="student-page py-4">

    <div class="student-page-header mb-4">
        <h1 class="student-page-title">Edit User</h1>
        <p class="student-page-subtitle">
            Update account information and role assignment.
        </p>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        var statusType = TempData["StatusType"] as string ?? "success";
        var alertClass = statusType == "error" ? "alert-danger" : "alert-success";

        <div class="alert @alertClass" role="alert">
            @statusMessage
        </div>
    }

    <div class="student-card">
        <form asp-controller="Admin" asp-action="UserEdit" method="post">
            <input asp-for="UserId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" asp-items="Model.AvailableRoles" class="form-select"></select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary">Cancel</a>
                <button type="button"
                        class="btn btn-outline-danger ms-auto"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteUserModal">
                    Delete User
                </button>
            </div>
        </form>
    </div>

    <div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="deleteUserModalLabel">Delete user account?</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    This will permanently remove <strong>@Model.Email</strong> and any related student, donor, volunteer, request, donation, and order records tied to that account.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form asp-controller="Admin" asp-action="DeleteUser" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <button type="submit" class="btn btn-danger">Yes, delete user</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
