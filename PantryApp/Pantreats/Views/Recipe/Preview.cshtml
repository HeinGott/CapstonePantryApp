@model Pantreats.Models.RecipeEditorViewModel

@{
    ViewData["Title"] = "Recipe Preview";
}

<div class="student-page-header mb-4">
    <h1>Recipe Preview</h1>
    <p> Student Recipe View</p>
</div>

<div class="student-card">

    <h2>@Model.Recipe.Title</h2>

    <img src="@(string.IsNullOrWhiteSpace(Model.Recipe.ImagePath)
                     ? "/images/pantreatsLogo.png"
                     : Model.Recipe.ImagePath)"
         class="recipe-image" />

    <p>@Model.Recipe.Description</p>

    <p>
        <strong>Meal Type:</strong>
        @Model.Recipe.MealType
    </p>

    <p>
        <strong>Dietary:</strong>
        @Model.Recipe.DietaryTags
    </p>

    <h3>Ingredients</h3>

    <ul>
        @foreach (var ingredient in Model.Ingredients)
        {
            <li>
                @ingredient.Quantity
                @ingredient.Unit
                @ingredient.CustomIngredientName

                @if (!string.IsNullOrWhiteSpace(ingredient.SubstituteIngredientName))
                {
                    <span class="text-muted">
                        (Substitute:
                        @ingredient.SubstituteIngredientName)
                    </span>
                }
            </li>
        }
    </ul>

    <h3>Instructions</h3>

    <p style="white-space:pre-wrap">
        @Model.Recipe.Instructions
    </p>

    <div class="d-flex justify-content-center gap-2 mt-4">

        <form asp-controller="Recipe"
              asp-action="Create"
              method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Recipe.Title" />
            <input type="hidden" asp-for="Recipe.Description" />
            <input type="hidden" asp-for="Recipe.MealType" />
            <input type="hidden" asp-for="Recipe.DietaryTags" />
            <input type="hidden" asp-for="Recipe.Instructions" />
            <input type="hidden" asp-for="IsImportedRecipe" value="true" />

            @for (int i = 0; i < Model.Ingredients.Count; i++)
            {
                <input type="hidden" name="Ingredients[@i].Quantity" value="@Model.Ingredients[i].Quantity" />
                <input type="hidden" name="Ingredients[@i].Unit" value="@Model.Ingredients[i].Unit" />
                <input type="hidden" name="Ingredients[@i].CustomIngredientName" value="@Model.Ingredients[i].CustomIngredientName" />
                <input type="hidden" name="Ingredients[@i].ImportedIngredientName" value="@Model.Ingredients[i].ImportedIngredientName" />
                <input type="hidden" name="Ingredients[@i].SubstituteIngredientName" value="@Model.Ingredients[i].SubstituteIngredientName" />
            }

            <button type="submit"
                    name="actionType"
                    value="BackToEdit"
                    class="btn btn-outline-secondary">
                Back to Edit
            </button>
        </form>

        <form asp-controller="Recipe"
              asp-action="Create"
              method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Recipe.Title" />
            <input type="hidden" asp-for="Recipe.Description" />
            <input type="hidden" asp-for="Recipe.MealType" />
            <input type="hidden" asp-for="Recipe.DietaryTags" />
            <input type="hidden" asp-for="Recipe.Instructions" />
            <input type="hidden" asp-for="IsImportedRecipe" value="true" />

            @for (int i = 0; i < Model.Ingredients.Count; i++)
            {
                <input type="hidden" name="Ingredients[@i].Quantity" value="@Model.Ingredients[i].Quantity" />
                <input type="hidden" name="Ingredients[@i].Unit" value="@Model.Ingredients[i].Unit" />
                <input type="hidden" name="Ingredients[@i].CustomIngredientName" value="@Model.Ingredients[i].CustomIngredientName" />
                <input type="hidden" name="Ingredients[@i].ImportedIngredientName" value="@Model.Ingredients[i].ImportedIngredientName" />
                <input type="hidden" name="Ingredients[@i].SubstituteIngredientName" value="@Model.Ingredients[i].SubstituteIngredientName" />
            }

            <button type="submit"
                    class="btn btn-primary">
                Looks Good
            </button>
        </form>

    </div>

</div>