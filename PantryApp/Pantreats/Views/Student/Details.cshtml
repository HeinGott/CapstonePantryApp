@{
    ViewData["Title"] = "Student Details";

    var studentId = ViewBag.StudentId;

    var studentName = "Jimmy Hendrix";
    var studentNumber = "10001";
    var email = "jhendrix392@sccsc.edu";
    var pointsAvailable = 0;

    var history = new List<dynamic>
    {
        new { Type = "Local Transaction", Date = "04/01/2026", Description = "Pantry visit", PointsUsed = 0 },
        new { Type = "Order", Date = "04/03/2026", Description = "Online pantry order", PointsUsed = 0 },
        new { Type = "Local Transaction", Date = "04/10/2026", Description = "In-person item pickup", PointsUsed = 0 },
        new { Type = "Order", Date = "04/15/2026", Description = "Scheduled order pickup", PointsUsed = 0 }
    };
}

<div class="student-details-page py-4">

    <div class="mb-3">
        <a asp-controller="Student" asp-action="Index" class="btn student-back-btn">
            ← Back to Students
        </a>
    </div>

    <div class="student-profile-card mb-4">
        <div>
            <h1 class="student-details-title mb-1">@studentName</h1>
            <p class="student-details-subtitle mb-0">
                Student ID Number: @studentNumber
            </p>
        </div>

        <div class="student-profile-grid mt-4">
            <div class="student-profile-item">
                <span>Email</span>
                <strong>@email</strong>
            </div>

            <div class="student-profile-item">
                <span>Points Available</span>
                <strong>@pointsAvailable</strong>
            </div>

            <div class="student-profile-item">
                <span>Student Record ID</span>
                <strong>@studentId</strong>
            </div>
        </div>
    </div>

    <div class="student-card">
        <div class="student-history-header mb-3">
            <div>
                <h2 class="student-section-title mb-1">History</h2>
                <p class="student-page-subtitle mb-0">
                    View local transactions and online orders in one place.
                </p>
            </div>

            <div class="student-filter-buttons">
                <button class="btn student-filter-btn active" onclick="filterHistory('all', this)">All</button>
                <button class="btn student-filter-btn" onclick="filterHistory('local transaction', this)">Local Transactions</button>
                <button class="btn student-filter-btn" onclick="filterHistory('order', this)">Orders</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table student-table align-middle mb-0" id="historyTable">
                <thead>
                    <tr>
                        <th onclick="sortTable('historyTable', 0, this)">Type</th>
                        <th onclick="sortTable('historyTable', 1, this)">Date</th>
                        <th onclick="sortTable('historyTable', 2, this)">Description</th>
                        <th onclick="sortTable('historyTable', 3, this)">Points Used</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in history)
                    {
                        <tr class="student-history-row">
                            <td>@item.Type</td>
                            <td>@item.Date</td>
                            <td>@item.Description</td>
                            <td>@item.PointsUsed</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function filterHistory(type, button) {
            let table = document.getElementById("historyTable");
            let rows = table.getElementsByTagName("tr");
            let buttons = document.getElementsByClassName("student-filter-btn");

            for (let i = 0; i < buttons.length; i++) {
                buttons[i].classList.remove("active");
            }

            button.classList.add("active");

            for (let i = 1; i < rows.length; i++) {
                let historyType = rows[i].cells[0].innerText.toLowerCase();

                if (type === "all" || historyType === type) {
                    rows[i].style.display = "";
                }
                else {
                    rows[i].style.display = "none";
                }
            }
        }

        function sortTable(tableId, columnNumber, header) {
            let table = document.getElementById(tableId);
            let tbody = table.tBodies[0];
            let rows = Array.from(tbody.rows);
            let currentSort = header.getAttribute("data-sort");

            let newSort = "asc";

            if (currentSort === "asc") {
                newSort = "desc";
            }

            let headers = table.querySelectorAll("th");

            headers.forEach(function (th) {
                th.removeAttribute("data-sort");
            });

            header.setAttribute("data-sort", newSort);

            rows.sort(function (a, b) {
                let firstValue = a.cells[columnNumber].innerText.trim().toLowerCase();
                let secondValue = b.cells[columnNumber].innerText.trim().toLowerCase();

                let firstDate = Date.parse(firstValue);
                let secondDate = Date.parse(secondValue);

                if (!isNaN(firstDate) && !isNaN(secondDate)) {
                    return newSort === "asc" ? firstDate - secondDate : secondDate - firstDate;
                }

                let firstNumber = parseFloat(firstValue);
                let secondNumber = parseFloat(secondValue);

                if (!isNaN(firstNumber) && !isNaN(secondNumber)) {
                    return newSort === "asc" ? firstNumber - secondNumber : secondNumber - firstNumber;
                }

                if (firstValue < secondValue) {
                    return newSort === "asc" ? -1 : 1;
                }

                if (firstValue > secondValue) {
                    return newSort === "asc" ? 1 : -1;
                }

                return 0;
            });

            rows.forEach(function (row) {
                tbody.appendChild(row);
            });
        }
    </script>
}