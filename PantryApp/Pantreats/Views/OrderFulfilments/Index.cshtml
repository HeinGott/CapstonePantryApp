@model Pantreats.Models.OrderFulfilmentViewModel

@{
    ViewData["Title"] = "Order Fulfilment";
}

<div class="fulfilment-page py-4">

    <div class="fulfilment-page-header mb-4">
        <h1 class="fulfilment-page-title">Order Fulfilment</h1>

        <p class="fulfilment-page-subtitle">
            Track orders from the moment they are placed through pickup and completion.
        </p>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="fulfilment-stat-card">
                <h5>Total Orders</h5>
                <h2>@Model.TotalOrders</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="fulfilment-stat-card">
                <h5>Order Placed</h5>
                <h2>@Model.OrderPlacedCount</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="fulfilment-stat-card">
                <h5>Ready for Pickup</h5>
                <h2>@Model.ReadyForPickupCount</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="fulfilment-stat-card">
                <h5>Completed</h5>
                <h2>@Model.CompletedCount</h2>
            </div>
        </div>

    </div>

    <div class="fulfilment-card">

        <form method="get" class="mb-4">
            <div class="row g-3">

                <div class="col-md-6">
                    <input class="form-control" type="text" name="searchText" value="@Model.SearchText"
                           placeholder="Search by order ID or email" />
                </div>

                <div class="col-md-4">
                    <select class="form-select" name="statusFilter">
                        <option value="">All Statuses</option>

                        @if (Model.StatusFilter == Pantreats.Models.OrderFulfilment.StatusOrderPlaced)
                        {
                            <option value="@Pantreats.Models.OrderFulfilment.StatusOrderPlaced" selected>Order placed
                            </option>
                        }
                        else
                        {
                            <option value="@Pantreats.Models.OrderFulfilment.StatusOrderPlaced">Order placed</option>
                        }

                        @if (Model.StatusFilter == Pantreats.Models.OrderFulfilment.StatusReadyForPickup)
                        {
                            <option value="@Pantreats.Models.OrderFulfilment.StatusReadyForPickup" selected>Order ready for
                                pickup</option>
                            }
                        else
                            {
                                <option value="@Pantreats.Models.OrderFulfilment.StatusReadyForPickup">Order ready for pickup
                                </option>
                            }

                            @if (Model.StatusFilter == Pantreats.Models.OrderFulfilment.StatusCompleted)
                            {
                                <option value="@Pantreats.Models.OrderFulfilment.StatusCompleted" selected>Completed</option>
                            }
                            else
                            {
                                <option value="@Pantreats.Models.OrderFulfilment.StatusCompleted">Completed</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" type="submit">
                            Search
                        </button>
                    </div>

                </div>
            </form>

            <div class="table-responsive">
                <table class="table fulfilment-table align-middle mb-0">

                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Email</th>
                            <th>Items</th>
                            <th>Status</th>
                            <th>Order Date</th>
                            <th>Ready Date</th>
                            <th>Completed Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.OrderFulfilments.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center">
                                    No fulfilment records found.
                                </td>
                            </tr>
                        }

                        @foreach (var item in Model.OrderFulfilments)
                        {
                            var normalizedStatus = Pantreats.Models.OrderFulfilment.NormalizeStatus(item.OrderStatus);
                            var statusClass = normalizedStatus switch
                            {
                                Pantreats.Models.OrderFulfilment.StatusCompleted => "is-complete",
                                Pantreats.Models.OrderFulfilment.StatusReadyForPickup => "is-ready",
                                _ => "is-pending"
                            };

                            var showReadyDate = !string.Equals(normalizedStatus,
                        Pantreats.Models.OrderFulfilment.StatusOrderPlaced, StringComparison.OrdinalIgnoreCase);

                            <tr class="fulfilment-row fulfilment-clickable-row"
                                data-href="@Url.Action("Details", "Order", new { id = item.OrderId })" tabindex="0" role="link"
                                aria-label="Open order @item.OrderId details">
                                <td>
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId"
                                       class="fulfilment-order-link">
                                        #@item.OrderId
                                    </a>
                                </td>
                                <td>@item.Order?.Email</td>
                                <td>@(item.Order?.OrderItems.Sum(orderItem => orderItem.OrderQuantity) ?? 0)</td>
                                <td>
                                    <span class="admin-status @statusClass">@normalizedStatus</span>
                                </td>
                                <td>@(item.Order != null ? item.Order.OrderDate.ToShortDateString() : string.Empty)</td>
                                <td>
                                    @if (showReadyDate)
                                    {
                                        @item.FulfilmentDate.ToShortDateString()
                                    }
                                    else
                                    {
                                        <span>Not ready yet</span>
                                    }
                                </td>
                                <td>
                                    @if (item.DateReceived.HasValue)
                                    {
                                        @item.DateReceived.Value.ToShortDateString()
                                    }
                                else
                                {
                                    <span>Not completed</span>
                                }
                            </td>

                        </tr>
                    }
                    </tbody>

                </table>
            </div>

        </div>

    </div>

    @section Scripts {
        <script>
            document.querySelectorAll('.fulfilment-clickable-row').forEach((row) => {
                row.addEventListener('click', (event) => {
                    if (event.target.closest('a, button, form, input, select, textarea')) {
                        return;
                    }

                    const href = row.dataset.href;
                    if (href) {
                        window.location.href = href;
                    }
                });

                row.addEventListener('keydown', (event) => {
                    if (event.key !== 'Enter' && event.key !== ' ') {
                        return;
                    }

                    event.preventDefault();
                    const href = row.dataset.href;
                    if (href) {
                        window.location.href = href;
                    }
                });
            });
        </script>
    }
