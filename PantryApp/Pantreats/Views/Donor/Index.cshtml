@model IEnumerable<Pantreats.Models.Donor>

@{
    ViewData["Title"] = "Donors";
}

<div class="donor-page py-4">

    <div class="donor-page-header mb-4">

        <div>
            <h1 class="donor-page-title mb-1">Donor</h1>
            <p class="donor-page-subtitle mb-0">
                View donors and manage donation sources.
            </p>
        </div>

    </div>

    <div class="student-card">

        <div class="table-responsive">

            <table class="table student-table align-middle mb-0" id="donorTable">

                <thead>
                    <tr>
                        <th onclick="sortTable('donorTable', 0, this)">Donor Name</th>
                        <th onclick="sortTable('donorTable', 1, this)">Phone Number</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var donor in Model)
                    {
                        <tr class="student-row"
                            onclick="goToDonor(@donor.DonorID)"
                            onkeydown="handleDonorRowKeydown(event, @donor.DonorID)"
                            tabindex="0"
                            role="link"
                            style="cursor: pointer;">

                            <td>
                                <strong>@donor.Name</strong>
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(donor.PhoneNumber)
                                    ? "Not added"
                                    : donor.PhoneNumber)
                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        function goToDonor(id) {
            window.location.href = '/Donor/Details/' + id;
        }

        function handleDonorRowKeydown(event, id) {
            if (event.key === "Enter" || event.key === " ") {
                event.preventDefault();
                goToDonor(id);
            }
        }

        function sortTable(tableId, columnNumber, header) {
            let table = document.getElementById(tableId);
            let tbody = table.tBodies[0];
            let rows = Array.from(tbody.rows);
            let currentSort = header.getAttribute("data-sort");

            let newSort = "asc";

            if (currentSort === "asc") {
                newSort = "desc";
            }

            let headers = table.querySelectorAll("th");

            headers.forEach(function (th) {
                th.removeAttribute("data-sort");
            });

            header.setAttribute("data-sort", newSort);

            rows.sort(function (a, b) {
                let firstValue = a.cells[columnNumber].innerText.trim().toLowerCase();
                let secondValue = b.cells[columnNumber].innerText.trim().toLowerCase();

                let firstNumber = parseFloat(firstValue);
                let secondNumber = parseFloat(secondValue);

                if (!isNaN(firstNumber) && !isNaN(secondNumber)) {
                    return newSort === "asc" ? firstNumber - secondNumber : secondNumber - firstNumber;
                }

                if (firstValue < secondValue) {
                    return newSort === "asc" ? -1 : 1;
                }

                if (firstValue > secondValue) {
                    return newSort === "asc" ? 1 : -1;
                }

                return 0;
            });

            rows.forEach(function (row) {
                tbody.appendChild(row);
            });
        }
    </script>
}
