@model Pantreats.Models.StudentApplicationStatusViewModel

@{
    ViewData["Title"] = "Application Status";
}

<div class="student-details-page py-4">
    <div class="student-profile-card">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h1 class="student-details-title mb-1">Application Status</h1>
                <p class="student-details-subtitle mb-0">
                    Track your pantry application and next steps here.
                </p>
            </div>

            <span class="badge bg-secondary">@Model.ApplicationStatus</span>
        </div>

        <div class="student-profile-grid mt-4">
            <div class="student-profile-item">
                <span>Name</span>
                <strong>@Model.FullName</strong>
            </div>
            <div class="student-profile-item">
                <span>Student ID</span>
                <strong>@Model.StudentId</strong>
            </div>
            <div class="student-profile-item">
                <span>Submitted</span>
                <strong>@Model.SubmittedAt.ToLocalTime().ToString("MM/dd/yyyy h:mm tt")</strong>
            </div>
            <div class="student-profile-item">
                <span>Reviewed</span>
                <strong>@(Model.ReviewedAt.HasValue ? Model.ReviewedAt.Value.ToLocalTime().ToString("MM/dd/yyyy h:mm tt") : "Not reviewed yet")</strong>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ReviewNotes))
        {
            <div class="mt-4">
                <h2 class="student-section-title mb-2">Notes From Admin</h2>
                <p class="mb-0">@Model.ReviewNotes</p>
            </div>
        }

        <div class="mt-4">
            @if (Model.ApplicationStatus == Pantreats.Models.ApplicationStatuses.Pending)
            {
                <p class="mb-0">Your application is pending review. You'll be able to access the shop as soon as an admin approves it.</p>
            }
            else if (Model.ApplicationStatus == Pantreats.Models.ApplicationStatuses.Approved)
            {
                <p class="mb-3">Your application has been approved. You can now use the pantry shop.</p>
                <a asp-controller="Shop" asp-action="Index" class="btn student-back-btn">Open Shop</a>
            }
            else if (Model.CanEditApplication)
            {
                <p class="mb-3">Your application needs updates before approval. You can edit and resubmit it now.</p>
                <a asp-action="Apply" class="btn student-back-btn">Edit Application</a>
            }
        </div>
    </div>
</div>
