@model Pantreats.Models.Donor

@{
    ViewData["Title"] = "Add Donor";
}

<section class="vendor-create-page">
    <div class="mb-4">
        <a asp-controller="Donor" asp-action="Index" class="btn btn-outline-secondary">
            ← Back to Donors
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="mb-2">Add Donor</h1>
            <p class="text-muted mb-4">
                Add a person or company that donates items to the pantry.
            </p>

            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Donor Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    Save Donor
                </button>
            </form>
        </div>
    </div>
</section>