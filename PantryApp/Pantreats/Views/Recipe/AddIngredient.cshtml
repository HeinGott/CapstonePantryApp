@model Pantreats.Models.RecipeIngredient

@{
    ViewData["Title"] = "Add Ingredient";
    var inventoryItems = ViewBag.InventoryItems as List<Pantreats.Models.Inventory>;
    var recipe = ViewBag.Recipe as Pantreats.Models.Recipe;
}

<div class="student-page-header mb-4">
    <div>
        <h1 class="student-page-title">Add Ingredient</h1>
        <p class="student-page-subtitle">@recipe?.Title</p>
    </div>
</div>

<div class="student-card">
    <form asp-controller="Recipe" asp-action="AddIngredient" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="RecipeId" />

        <div class="mb-3">
            <label class="form-label">Inventory Item</label>
            <select asp-for="InventoryItemId" class="form-control">
                <option value="">-- Non-inventory item --</option>
                @foreach (var item in inventoryItems ?? new())
                {
                    <option value="@item.ItemId">@item.ItemName</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="CustomIngredientName" class="form-label">
                Custom Ingredient Name
            </label>
            <input asp-for="CustomIngredientName"
                   class="form-control"
                   placeholder="Salt, pepper, olive oil, etc." />
        </div>

        <div class="mb-3">
            <label asp-for="Quantity" class="form-label">Quantity</label>
            <input asp-for="Quantity" class="form-control" placeholder="1, 2, 1/2" />
        </div>

        <div class="mb-3">
            <label asp-for="Unit" class="form-label">Unit</label>
            <input asp-for="Unit" class="form-control" placeholder="cup, can, tbsp, oz" />
        </div>

        <button type="submit" class="btn btn-primary">
            Save Ingredient
        </button>

        <a asp-controller="Recipe"
           asp-action="Details"
           asp-route-id="@Model.RecipeId"
           class="btn btn-outline-secondary">
            Cancel
        </a>
    </form>
</div>